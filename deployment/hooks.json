[
  {
    "id": "deploy-arifos",
    "execute-command": "/var/scripts/deploy_from_git.sh",
    "command-working-directory": "/usr/src/app",
    "response-message": "Deploying arifOS from git...",
    "trigger-rule": {
      "and": [
        {
          "match": {
            "type": "payload-hmac-sha256",
            "secret": "{{ getenv \"WEBHOOK_SECRET\" }}",
            "parameter": {
              "source": "header",
              "name": "X-Hub-Signature-256"
            }
          }
        },
        {
          "match": {
            "type": "value",
            "value": "refs/heads/main",
            "parameter": {
              "source": "payload",
              "name": "ref"
            }
          }
        }
      ]
    }
  },
  {
    "id": "restart-openclaw",
    "execute-command": "/var/scripts/restart_openclaw.sh",
    "command-working-directory": "/",
    "response-message": "Restarting OpenClaw Gateway...",
    "trigger-rule": {
      "match": {
        "type": "value",
        "value": "openclaw-restart-888",
        "parameter": {
          "source": "header",
          "name": "X-Restart-Token"
        }
      }
    }
  }
]
