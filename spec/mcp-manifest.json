{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.ariffazil/arifos-mcp",
  "version": "2026.03.10-SEAL",
  "title": "arifOS Sovereign Governance MCP",
  "description": "Constitutional AI governance server with a 7-tool public surface, 7 public prompts, 14 public resources, Trinity engines (ΔΩΨ), and F1-F13 floor enforcement.",
  "websiteUrl": "https://arifos.arif-fazil.com",
  "vendor": {
    "name": "arifOS",
    "url": "https://arifos.arif-fazil.com"
  },
  "license": "AGPL-3.0-only",
  "repository": {
    "url": "https://github.com/ariffazil/arifosmcp",
    "source": "github"
  },
  "runtime": {
    "python": ">=3.12",
    "entrypoint": "python -m arifosmcp.runtime",
    "dependencies": [
      "fastmcp==3.1.0"
    ]
  },
  "deployment": {
    "default_transport": "http",
    "host": "0.0.0.0",
    "port": 8080,
    "path": "/mcp",
    "log_level": "INFO"
  },
  "packages": [
    {
      "registryType": "pypi",
      "identifier": "arifos",
      "version": "2026.03.10-SEAL",
      "transport": {
        "type": "stdio"
      }
    },
    {
      "registryType": "oci",
      "identifier": "docker.io/arifazil/arifosmcp:forge-20260310",
      "transport": {
        "type": "streamable-http",
        "url": "https://arifosmcp.arif-fazil.com/mcp"
      }
    }
  ],
  "remotes": [
    {
      "type": "sse",
      "url": "https://arifosmcp.arif-fazil.com/sse"
    },
    {
      "type": "streamable-http",
      "url": "https://arifosmcp.arif-fazil.com/mcp",
      "authentication": {
        "type": "none"
      }
    }
  ],
  "tools": {
    "arifOS_kernel": {
      "stage": "444_ROUTER",
      "trinity": "ALL",
      "floors": [
        "F1-F13"
      ],
      "description": "The arifOS Intelligence Kernel. Runs the full constitutional reasoning pipeline and should be the primary entrypoint for non-trivial tasks.",
      "inputSchema": {
        "type": "object",
        "required": [
          "query"
        ],
        "properties": {
          "query": {
            "type": "string",
            "description": "Task or question to evaluate."
          },
          "context": {
            "type": "string",
            "default": ""
          },
          "risk_tier": {
            "type": "string",
            "enum": [
              "low",
              "medium",
              "high",
              "critical"
            ],
            "default": "medium"
          },
          "actor_id": {
            "type": "string",
            "default": "anonymous"
          },
          "auth_context": {
            "type": "object",
            "description": "Optional continuity envelope from init_anchor_state. Required for anchored follow-up kernel calls."
          },
          "use_memory": {
            "type": "boolean",
            "default": true
          },
          "use_heart": {
            "type": "boolean",
            "default": true
          },
          "use_critique": {
            "type": "boolean",
            "default": true
          },
          "allow_execution": {
            "type": "boolean",
            "default": false
          },
          "debug": {
            "type": "boolean",
            "default": false
          },
          "dry_run": {
            "type": "boolean",
            "default": false
          },
          "requested_persona": {
            "type": "string",
            "enum": [
              "architect",
              "engineer",
              "auditor",
              "validator"
            ]
          }
        },
        "additionalProperties": false
      }
    },
    "search_reality": {
      "stage": "111_SENSE",
      "trinity": "Δ Delta",
      "floors": [
        "F2",
        "F12"
      ],
      "description": "Find real-world sources and factual grounding before reasoning.",
      "inputSchema": {
        "type": "object",
        "required": [
          "query"
        ],
        "properties": {
          "query": {
            "type": "string",
            "description": "Topic to ground with external facts."
          }
        },
        "additionalProperties": false
      },
      "readonly": true
    },
    "ingest_evidence": {
      "stage": "222_REALITY",
      "trinity": "Δ Delta",
      "floors": [
        "F2",
        "F11",
        "F12"
      ],
      "description": "Fetch or extract evidence from a URL, document, or file path.",
      "inputSchema": {
        "type": "object",
        "required": [
          "url"
        ],
        "properties": {
          "url": {
            "type": "string",
            "description": "URL to ingest into governed context."
          }
        },
        "additionalProperties": false
      },
      "readonly": true
    },
    "session_memory": {
      "stage": "555_MEMORY",
      "trinity": "Ω Omega",
      "floors": [
        "F4",
        "F7",
        "F13"
      ],
      "description": "Store, retrieve, or forget session context and reasoning artifacts.",
      "inputSchema": {
        "type": "object",
        "required": [
          "session_id",
          "operation"
        ],
        "properties": {
          "session_id": {
            "type": "string"
          },
          "operation": {
            "type": "string",
            "enum": [
              "store",
              "retrieve",
              "forget",
              "search"
            ]
          },
          "content": {
            "type": "string"
          },
          "memory_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "top_k": {
            "type": "integer",
            "minimum": 1,
            "default": 5
          }
        },
        "additionalProperties": false
      }
    },
    "audit_rules": {
      "stage": "333_MIND",
      "trinity": "Δ Delta",
      "floors": [
        "F2",
        "F8",
        "F10"
      ],
      "description": "Inspect the 13 constitutional floors and verify governance logic.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "session_id": {
            "type": "string",
            "default": "global"
          }
        },
        "additionalProperties": false
      },
      "readonly": true
    },
    "check_vital": {
      "stage": "000_INIT",
      "trinity": "Ω Omega",
      "floors": [
        "F4",
        "F5",
        "F7"
      ],
      "description": "Read-only system health snapshot, reporting diagnostics and vitality signals.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "session_id": {
            "type": "string",
            "default": "global"
          }
        },
        "additionalProperties": false
      },
      "readonly": true
    },
    "open_apex_dashboard": {
      "stage": "888_JUDGE",
      "trinity": "Ψ Psi",
      "floors": [
        "F3",
        "F8",
        "F13"
      ],
      "description": "Open the APEX constitutional dashboard for live metrics and trace visibility.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "session_id": {
            "type": "string",
            "default": "global"
          }
        },
        "additionalProperties": false
      },
      "readonly": true
    }
  },
  "prompts": [
    {
      "name": "arifos_kernel_prompt",
      "targetTool": "arifOS_kernel",
      "description": "Route governed work to the kernel."
    },
    {
      "name": "search_reality_prompt",
      "targetTool": "search_reality",
      "description": "Ground claims with external facts."
    },
    {
      "name": "ingest_evidence_prompt",
      "targetTool": "ingest_evidence",
      "description": "Load a source into evidence context."
    },
    {
      "name": "session_memory_prompt",
      "targetTool": "session_memory",
      "description": "Manage governed session continuity."
    },
    {
      "name": "audit_rules_prompt",
      "targetTool": "audit_rules",
      "description": "Inspect constitutional floor logic."
    },
    {
      "name": "check_vital_prompt",
      "targetTool": "check_vital",
      "description": "Read health and vitality telemetry."
    },
    {
      "name": "open_apex_dashboard_prompt",
      "targetTool": "open_apex_dashboard",
      "description": "Open the dashboard surface for live governed metrics."
    }
  ],
  "resources": [
    {
      "uri": "canon://index",
      "description": "High-level arifOS canon map."
    },
    {
      "uri": "canon://tools",
      "description": "Canonical public tool surface."
    },
    {
      "uri": "canon://floors",
      "description": "arifOS 13 constitutional floors."
    },
    {
      "uri": "canon://metabolic-loop",
      "description": "Public kernel flow and stages."
    },
    {
      "uri": "governance://law",
      "description": "Verdict hierarchy and floor invariants."
    },
    {
      "uri": "eval://metabolic-workflows",
      "description": "Standard 000-999 workflow recipes."
    },
    {
      "uri": "eval://floors-thresholds",
      "description": "Numeric thresholds for floors."
    },
    {
      "uri": "schema://tools/input",
      "description": "Canonical JSON Schema input specs for public tools."
    },
    {
      "uri": "schema://tools/output",
      "description": "RuntimeEnvelope output schema."
    },
    {
      "uri": "schema://opex",
      "description": "Epistemic intake schema."
    },
    {
      "uri": "schema://apex",
      "description": "Governance output schema."
    },
    {
      "uri": "vault://latest",
      "description": "Latest sealed VAULT entries."
    },
    {
      "uri": "telemetry://summary",
      "description": "Governance telemetry summary."
    },
    {
      "uri": "ui://apex/dashboard-v2.html",
      "description": "Packaged APEX dashboard asset."
    }
  ],
  "schema": {
    "input": {
      "arifOS_kernel": {
        "type": "object",
        "required": [
          "query"
        ],
        "properties": {
          "query": {
            "type": "string",
            "description": "Task or question to evaluate."
          },
          "context": {
            "type": "string",
            "default": ""
          },
          "risk_tier": {
            "type": "string",
            "enum": [
              "low",
              "medium",
              "high",
              "critical"
            ],
            "default": "medium"
          },
          "actor_id": {
            "type": "string",
            "default": "anonymous"
          },
          "auth_context": {
            "type": "object",
            "description": "Optional continuity envelope from init_anchor_state. Required for anchored follow-up kernel calls."
          },
          "use_memory": {
            "type": "boolean",
            "default": true
          },
          "use_heart": {
            "type": "boolean",
            "default": true
          },
          "use_critique": {
            "type": "boolean",
            "default": true
          },
          "allow_execution": {
            "type": "boolean",
            "default": false
          },
          "debug": {
            "type": "boolean",
            "default": false
          },
          "dry_run": {
            "type": "boolean",
            "default": false
          },
          "requested_persona": {
            "type": "string",
            "enum": [
              "architect",
              "engineer",
              "auditor",
              "validator"
            ]
          }
        },
        "additionalProperties": false
      },
      "search_reality": {
        "type": "object",
        "required": [
          "query"
        ],
        "properties": {
          "query": {
            "type": "string",
            "description": "Topic to ground with external facts."
          }
        },
        "additionalProperties": false
      },
      "ingest_evidence": {
        "type": "object",
        "required": [
          "url"
        ],
        "properties": {
          "url": {
            "type": "string",
            "description": "URL to ingest into governed context."
          }
        },
        "additionalProperties": false
      },
      "session_memory": {
        "type": "object",
        "required": [
          "session_id",
          "operation"
        ],
        "properties": {
          "session_id": {
            "type": "string"
          },
          "operation": {
            "type": "string",
            "enum": [
              "store",
              "retrieve",
              "forget",
              "search"
            ]
          },
          "content": {
            "type": "string"
          },
          "memory_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "top_k": {
            "type": "integer",
            "minimum": 1,
            "default": 5
          }
        },
        "additionalProperties": false
      },
      "audit_rules": {
        "type": "object",
        "properties": {
          "session_id": {
            "type": "string",
            "default": "global"
          }
        },
        "additionalProperties": false
      },
      "check_vital": {
        "type": "object",
        "properties": {
          "session_id": {
            "type": "string",
            "default": "global"
          }
        },
        "additionalProperties": false
      },
      "open_apex_dashboard": {
        "type": "object",
        "properties": {
          "session_id": {
            "type": "string",
            "default": "global"
          }
        },
        "additionalProperties": false
      }
    },
    "output": {
      "type": "object",
      "description": "RuntimeEnvelope (v1.0.0) — common return shape for all public arifOS tools.",
      "required": [
        "ok",
        "tool",
        "session_id",
        "stage",
        "verdict",
        "status",
        "metrics",
        "trace",
        "authority",
        "payload",
        "errors",
        "meta"
      ],
      "properties": {
        "ok": {
          "type": "boolean",
          "description": "Transport success."
        },
        "tool": {
          "type": "string",
          "description": "Tool name."
        },
        "session_id": {
          "type": "string",
          "description": "Active session ID."
        },
        "stage": {
          "type": "string",
          "description": "Owning stage/organ."
        },
        "verdict": {
          "type": "string",
          "enum": [
            "SEAL",
            "PROVISIONAL",
            "PARTIAL",
            "SABAR",
            "HOLD",
            "HOLD_888",
            "VOID"
          ]
        },
        "status": {
          "type": "string",
          "enum": [
            "SUCCESS",
            "ERROR",
            "TIMEOUT",
            "DRY_RUN"
          ]
        },
        "metrics": {
          "type": "object",
          "properties": {
            "truth": {
              "type": "number"
            },
            "clarity_delta": {
              "type": "number"
            },
            "confidence": {
              "type": "number"
            },
            "peace": {
              "type": "number"
            },
            "vitality": {
              "type": "number"
            },
            "entropy_delta": {
              "type": "number"
            },
            "authority": {
              "type": "number"
            },
            "risk": {
              "type": "number"
            }
          }
        },
        "trace": {
          "type": "object",
          "description": "Stage path summary."
        },
        "authority": {
          "type": "object",
          "properties": {
            "actor_id": {
              "type": "string"
            },
            "level": {
              "type": "string"
            },
            "human_required": {
              "type": "boolean"
            },
            "approval_scope": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "auth_state": {
              "type": "string"
            }
          }
        },
        "payload": {
          "type": "object",
          "description": "Tool-specific result data."
        },
        "errors": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "code": {
                "type": "string"
              },
              "message": {
                "type": "string"
              },
              "stage": {
                "type": "string"
              },
              "recoverable": {
                "type": "boolean"
              }
            }
          }
        },
        "meta": {
          "type": "object",
          "properties": {
            "schema_version": {
              "type": "string"
            },
            "timestamp": {
              "type": "string"
            },
            "debug": {
              "type": "boolean"
            },
            "dry_run": {
              "type": "boolean"
            }
          }
        }
      },
      "additionalProperties": true
    }
  },
  "trinity": {
    "delta": {
      "symbol": "Δ",
      "name": "Mind",
      "role": "AGI Reasoning",
      "stages": [
        "000",
        "111",
        "333"
      ],
      "floors": [
        "F2",
        "F4",
        "F7",
        "F8"
      ]
    },
    "omega": {
      "symbol": "Ω",
      "name": "Heart",
      "role": "ASI Safety",
      "stages": [
        "555",
        "666"
      ],
      "floors": [
        "F5",
        "F6",
        "F9"
      ]
    },
    "psi": {
      "symbol": "Ψ",
      "name": "Soul",
      "role": "APEX Judgment",
      "stages": [
        "777",
        "888",
        "999"
      ],
      "floors": [
        "F1",
        "F3",
        "F10",
        "F11",
        "F12",
        "F13"
      ]
    }
  }
}
