#!/bin/bash
# ============================================================
# PRE-COMMIT HOOK — arifOS AAA Secret Scanner
# WAJIB gate: F1 AMANAH enforcement
# Blocks commits containing untracked secrets.
# Skip: git commit --no-verify (emergency only — SABAR)
# ============================================================
set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

# ── Colors ──────────────────────────────────────────────────
RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
NC='\033[0m' # No Color

echo "🔒 Running AAA Wajib Secret Gate..."

# ── 1. Pattern scan (fast regex — catches known secret formats) ──────────────
echo "  [1/2] Pattern scan (Telegram/GitHub/API keys)..."

PATTERNS=(
    'bot[0-9]+:[A-Za-z0-9_\-]{20,}'
    'gh[pousr]_[A-Za-z0-9_]{35,}'
    'sk-[A-Za-z0-9_\-]{30,}'
    'AKIA[A-Z0-9]{16}'
)

EXCLUDE_DIRS="_archive memory secrets .git node_modules"

BLOCKED_FILES=$(git diff --cached --name-only)
FOUND_BAD=0
declare -a FLAGRED_LINES=()

for file in $BLOCKED_FILES; do
    # Skip excluded dirs
    skip=0
    for ex in $EXCLUDE_DIRS; do
        if [[ "$file" == $ex/* ]]; then skip=1; break; fi
    done
    [[ $skip -eq 1 ]] && continue
    [[ -d "$file" ]] && continue

    # Scan diff content
    CONTENT=$(git diff --cached "$file")
    for pat in "${PATTERNS[@]}"; do
        if echo "$CONTENT" | grep -qE "$pat"; then
            MATCHES=$(echo "$CONTENT" | grep -nE "$pat" | head -3)
            echo -e "  ${RED}🚫 $pat${NC} in staged file: $file"
            echo "$MATCHES" | while IFS=: read -r linenum match; do
                echo -e "      ${YELLOW}line $linenum: ${match:0:60}...${NC}"
            done
            FOUND_BAD=1
        fi
    done
done

if [ $FOUND_BAD -eq 1 ]; then
    echo -e "\n${RED}🛑 BLOCKED — Known secret patterns in staged files${NC}"
    echo "Remove secrets before committing."
    echo "To check which files: git diff --cached | grep -E 'bot[0-9]|gh_|sk-|AKIA'"
    exit 1
fi
echo -e "  ${GREEN}✅ No known secret patterns detected${NC}"

# ── 2. detect-secrets baseline comparison ───────────────────────────────────
echo "  [2/2] detect-secrets baseline comparison..."

if ! command -v detect-secrets &>/dev/null; then
    echo -e "  ${YELLOW}⚠️  detect-secrets not installed — pip install detect-secrets${NC}"
    echo "  Skipping baseline scan. WARNING: secrets may slip through."
else
    # Scan current state (excluding known-legacy dirs)
    SCAN_TMP=$(mktemp)
    detect-secrets scan . --exclude-files '_archive/.*' --exclude-files 'memory/.*' \
        --exclude-files 'secrets/.*' --exclude-files 'skills/.*/_meta\.json' > "$SCAN_TMP" 2>/dev/null || true

    if [ ! -s "$SCAN_TMP" ]; then
        echo -e "  ${YELLOW}⚠️  detect-secrets scan returned empty — skipping${NC}"
    else
        # Load baseline
        if [ -f ".secrets.baseline" ]; then
            BLOCKED=0
            echo "    Checking against .secrets.baseline..."

            NEW=$(python3 -c "
import json, sys

with open('$REPO_ROOT/.secrets.baseline') as f:
    baseline = json.load(f)
with open('$SCAN_TMP') as f:
    current = json.load(f)

baseline_map = {}
for fname, entries in baseline.get('results', {}).items():
    baseline_map[fname] = {e['hashed_secret'] for e in entries}

new_secrets = []
for fname, entries in current.get('results', {}).items():
    # Skip excluded dirs
    skip = False
    for ex in ['_archive/', 'memory/', 'secrets/', 'skills/']:
        if fname.startswith(ex):
            skip = True
            break
    if skip:
        continue
    for entry in entries:
        h = entry['hashed_secret']
        if fname not in baseline_map or h not in baseline_map[fname]:
            new_secrets.append((entry['type'], fname, entry['line_number']))

if new_secrets:
    print('BLOCK')
    for t, f, l in new_secrets:
        print(f'  🚫 NEW: {t} in {f}:{l}')
else:
    print('OK')
" 2>/dev/null)

            if [ "${NEW:-OK}" = "BLOCK" ]; then
                echo -e "\n${RED}🛑 BLOCKED — New secrets not in .secrets.baseline${NC}"
                echo "These secrets were detected AND are NOT in the baseline:"
                python3 -c "
import json
with open('$SCAN_TMP') as f: current = json.load(f)
with open('$REPO_ROOT/.secrets.baseline') as f: baseline = json.load(f)
baseline_map = {}
for fname, entries in baseline.get('results', {}).items():
    baseline_map[fname] = {e['hashed_secret'] for e in entries}
for fname, entries in current.get('results', {}).items():
    skip = any(fname.startswith(ex) for ex in ['_archive/', 'memory/', 'secrets/', 'skills/'])
    if skip: continue
    for entry in entries:
        h = entry['hashed_secret']
        if fname not in baseline_map or h not in baseline_map[fname]:
            print(f'  🚫 {entry[\"type\"]} in {fname}:{entry[\"line_number\"]}')
" 2>/dev/null
                echo ""
                echo "FIX OPTIONS:"
                echo "  1. Remove the secret from the file (preferred)"
                echo "  2. Audit new baseline: detect-secrets scan . > .secrets.baseline"
                echo "     Then: git add .secrets.baseline && git commit --amend"
                BLOCKED=1
            fi
        else
            echo -e "  ${YELLOW}⚠️  No .secrets.baseline found — skipping baseline check${NC}"
            echo "  Run: detect-secrets scan . > .secrets.baseline"
        fi
    fi

    rm -f "$SCAN_TMP"

    if [ "${BLOCKED:-0}" = "1" ]; then
        exit 1
    fi
fi

echo -e "\n${GREEN}✅ WAJIB gate PASSED — no new secrets detected${NC}"
echo ""
echo "Reminder: This blocks NEW secrets. Historical secrets in _archive/ and memory/"
echo "are excluded from pre-commit but WILL appear in GitHub Actions scan."
echo "Clean them up when ready: git filter-branch or BFG Repo-Cleaner."
exit 0
