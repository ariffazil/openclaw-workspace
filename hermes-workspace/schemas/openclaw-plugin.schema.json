{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aaa.arif-fazil.com/schemas/openclaw-plugin.schema.json",
  "title": "AAA OpenClaw Plugin Policy",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "id": {
      "$ref": "./common.schema.json#/$defs/id"
    },
    "name": {
      "$ref": "./common.schema.json#/$defs/nonEmptyString"
    },
    "source": {
      "$ref": "./common.schema.json#/$defs/nonEmptyString"
    },
    "version": {
      "$ref": "./common.schema.json#/$defs/nonEmptyString"
    },
    "pinned": {
      "type": "boolean"
    },
    "enabled": {
      "type": "boolean"
    },
    "approval_policy": {
      "$ref": "./common.schema.json#/$defs/approvalPolicy"
    },
    "permissions": {
      "type": "array",
      "items": {
        "$ref": "./common.schema.json#/$defs/nonEmptyString"
      },
      "uniqueItems": true
    },
    "hosts": {
      "$ref": "./common.schema.json#/$defs/stringIdArray"
    }
  },
  "required": [
    "id",
    "name",
    "source",
    "version",
    "pinned",
    "enabled",
    "approval_policy",
    "permissions",
    "hosts"
  ]
}
