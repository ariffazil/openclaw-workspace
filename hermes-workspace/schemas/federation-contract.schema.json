{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aaa.arif-fazil.com/schemas/federation-contract.schema.json",
  "title": "AAA Federation Contract",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "id": {
      "$ref": "./common.schema.json#/$defs/id"
    },
    "name": {
      "$ref": "./common.schema.json#/$defs/nonEmptyString"
    },
    "stage": {
      "const": "111"
    },
    "domain_plane": {
      "$ref": "./common.schema.json#/$defs/domainPlane"
    },
    "purpose": {
      "$ref": "./common.schema.json#/$defs/nonEmptyString"
    },
    "deployment": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "hosting_model": {
          "type": "string",
          "enum": [
            "static-site",
            "server-runtime"
          ]
        },
        "public_base_url": {
          "type": "string",
          "format": "uri"
        },
        "runtime_bridge_ref": {
          "$ref": "./common.schema.json#/$defs/nonEmptyString"
        },
        "notes": {
          "$ref": "./common.schema.json#/$defs/nonEmptyString"
        }
      },
      "required": [
        "hosting_model",
        "public_base_url",
        "runtime_bridge_ref",
        "notes"
      ]
    },
    "public_surfaces": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "id": {
            "$ref": "./common.schema.json#/$defs/id"
          },
          "path": {
            "$ref": "./common.schema.json#/$defs/nonEmptyString"
          },
          "url": {
            "type": "string",
            "format": "uri"
          },
          "media_type": {
            "$ref": "./common.schema.json#/$defs/nonEmptyString"
          },
          "status": {
            "type": "string",
            "enum": [
              "live",
              "hold"
            ]
          },
          "role": {
            "$ref": "./common.schema.json#/$defs/nonEmptyString"
          },
          "source_path": {
            "$ref": "./common.schema.json#/$defs/nonEmptyString"
          }
        },
        "required": [
          "id",
          "path",
          "url",
          "media_type",
          "status",
          "role"
        ]
      }
    },
    "trust_tiers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "id": {
            "$ref": "./common.schema.json#/$defs/id"
          },
          "auth_schemes": {
            "type": "array",
            "items": {
              "$ref": "./common.schema.json#/$defs/id"
            },
            "minItems": 1,
            "uniqueItems": true
          },
          "require_mtls": {
            "type": "boolean"
          },
          "write_policy": {
            "$ref": "./common.schema.json#/$defs/approvalPolicy"
          }
        },
        "required": [
          "id",
          "auth_schemes",
          "require_mtls",
          "write_policy"
        ]
      }
    },
    "ingress_surfaces": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "id": {
            "$ref": "./common.schema.json#/$defs/id"
          },
          "path": {
            "$ref": "./common.schema.json#/$defs/nonEmptyString"
          },
          "transport": {
            "$ref": "./common.schema.json#/$defs/nonEmptyString"
          },
          "status": {
            "type": "string",
            "enum": [
              "live",
              "hold"
            ]
          },
          "auth_policy_ref": {
            "$ref": "./common.schema.json#/$defs/nonEmptyString"
          },
          "allowed_peers_ref": {
            "$ref": "./common.schema.json#/$defs/nonEmptyString"
          },
          "skills_exposure_ref": {
            "$ref": "./common.schema.json#/$defs/nonEmptyString"
          },
          "registry_ref": {
            "$ref": "./common.schema.json#/$defs/nonEmptyString"
          },
          "runtime_bridge_ref": {
            "$ref": "./common.schema.json#/$defs/nonEmptyString"
          },
          "hold_reason": {
            "$ref": "./common.schema.json#/$defs/nonEmptyString"
          }
        },
        "required": [
          "id",
          "path",
          "transport",
          "status",
          "auth_policy_ref",
          "allowed_peers_ref",
          "skills_exposure_ref",
          "registry_ref",
          "runtime_bridge_ref",
          "hold_reason"
        ]
      }
    },
    "invariants": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "id": {
            "$ref": "./common.schema.json#/$defs/id"
          },
          "rule": {
            "$ref": "./common.schema.json#/$defs/nonEmptyString"
          }
        },
        "required": [
          "id",
          "rule"
        ]
      }
    }
  },
  "required": [
    "version",
    "id",
    "name",
    "stage",
    "domain_plane",
    "purpose",
    "deployment",
    "public_surfaces",
    "trust_tiers",
    "ingress_surfaces",
    "invariants"
  ]
}
