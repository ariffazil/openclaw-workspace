{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aaa.arif-fazil.com/schemas/init-contract.schema.json",
  "title": "AAA 000 INIT Contract",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "integer",
      "const": 1
    },
    "id": {
      "$ref": "./common.schema.json#/$defs/id"
    },
    "name": {
      "$ref": "./common.schema.json#/$defs/nonEmptyString"
    },
    "purpose": {
      "$ref": "./common.schema.json#/$defs/nonEmptyString"
    },
    "required_root_canons": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "./common.schema.json#/$defs/nonEmptyString"
      }
    },
    "boot_sequence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "step": {
            "$ref": "./common.schema.json#/$defs/id"
          },
          "path": {
            "$ref": "./common.schema.json#/$defs/nonEmptyString"
          },
          "required": {
            "type": "boolean"
          }
        },
        "required": [
          "step",
          "path",
          "required"
        ]
      }
    },
    "state_anchors": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "id": {
            "$ref": "./common.schema.json#/$defs/id"
          },
          "required_fields": {
            "type": "array",
            "minItems": 1,
            "items": {
              "$ref": "./common.schema.json#/$defs/nonEmptyString"
            }
          }
        },
        "required": [
          "id",
          "required_fields"
        ]
      }
    },
    "outputs": {
      "type": "array",
      "items": {
        "$ref": "./common.schema.json#/$defs/nonEmptyString"
      }
    },
    "hold_conditions": {
      "type": "array",
      "items": {
        "$ref": "./common.schema.json#/$defs/nonEmptyString"
      }
    },
    "telemetry": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "required": {
          "type": "boolean"
        },
        "fields": {
          "type": "array",
          "items": {
            "$ref": "./common.schema.json#/$defs/nonEmptyString"
          }
        }
      },
      "required": [
        "required",
        "fields"
      ]
    },
    "invariants": {
      "type": "array",
      "items": {
        "$ref": "./common.schema.json#/$defs/nonEmptyString"
      }
    }
  },
  "required": [
    "version",
    "id",
    "name",
    "purpose",
    "required_root_canons",
    "boot_sequence",
    "state_anchors",
    "outputs",
    "hold_conditions",
    "telemetry",
    "invariants"
  ]
}
