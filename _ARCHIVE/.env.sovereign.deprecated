# arifOS PostgreSQL Only — No SQLite Fallback
# F1 Amanah: Real persistence atau FAIL

# Database (REQUIRED)
DATABASE_URL=postgresql://arifos:constitutional2026@localhost:5432/arifos_production
VAULT_BACKEND=postgres

# Constitutional Mode
ARIFOS_MODE=SOVEREIGN
BIND_HOST=127.0.0.1
BIND_PORT=8000

# Telegram (F11 Command Authority)
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# API Keys (F3 Tri-Witness)
BRAVE_API_KEY=your_brave_key_here
