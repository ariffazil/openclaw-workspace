{
  "$schema": "https://registry.modelcontextprotocol.io/v0.1/schema/2025-12-11/server.schema.json",
  "name": "io.github.ariffazil/arifos",
  "version": "60.0.0",
  "description": "Constitutional AI Governance with 13 enforced floors (F1-F13) and tri-witness consensus for LLMs.",
  "vendor": {
    "name": "arifOS",
    "url": "https://arifos.arif-fazil.com"
  },
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "https://github.com/ariffazil/arifOS"
  },

  "packages": [
    {
      "registryType": "pypi",
      "identifier": "arifos",
      "version": "60.0.0",
      "transport": {
        "type": "stdio",
        "command": "python -m aaa_mcp"
      }
    },
    {
      "registryType": "dockerhub",
      "identifier": "ariffazil/arifos",
      "version": "v60.0",
      "transport": {
        "type": "http",
        "url": "https://aaamcp.arif-fazil.com/mcp"
      }
    },
    {
      "registryType": "dockerhub",
      "identifier": "ariffazil/arifos",
      "version": "v60.0",
      "transport": {
        "type": "sse",
        "url": "https://aaamcp.arif-fazil.com/sse"
      }
    }
  ],
  "tools": [
    {
      "name": "init_gate",
      "description": "000_INIT: Session ignition with F11 Authority (Chain of Command) and F12 Injection Defense"
    },
    {
      "name": "forge_pipeline",
      "description": "000-999: Unified constitutional pipeline enforcing all F1-F13 floors with metabolic loop"
    },
    {
      "name": "agi_sense",
      "description": "111_SENSE: Intent classification and lane routing with F4 Clarity enforcement"
    },
    {
      "name": "agi_think",
      "description": "222_THINK: Hypothesis generation with F2 Truth (>=0.99) and F7 Humility (Ω₀ bounds)"
    },
    {
      "name": "agi_reason",
      "description": "333_REASON: Logic and deduction with F2 Truth, F4 Clarity, and F7 Uncertainty declaration"
    },
    {
      "name": "reality_search",
      "description": "Reality grounding via web search with F10 Ontology validation"
    },
    {
      "name": "asi_empathize",
      "description": "555_EMPATHY: Impact analysis and stakeholder protection with F5 Peace² and F6 Empathy"
    },
    {
      "name": "asi_align",
      "description": "666_ALIGN: Ethics and policy alignment with F5, F6, and F9 Anti-Hantu"
    },
    {
      "name": "apex_verdict",
      "description": "888_JUDGE: Final judgment with F3 Consensus (W₃>=0.95), F8 Genius (G>=0.80), F9 Anti-Hantu"
    },
    {
      "name": "vault_seal",
      "description": "999_SEAL: Immutable audit with F1 Amanah (reversibility) and F3 Tri-Witness consensus"
    }
  ],
  "categories": ["governance", "safety", "compliance", "security", "audit"],
  "tags": [
    "constitutional-ai",
    "ai-governance",
    "hallucination-prevention",
    "audit-trail",
    "enterprise-safety",
    "tri-witness-consensus",
    "thermodynamic-governance"
  ],
  "features": {
    "streaming": true,
    "batch": false,
    "authorization": {
      "type": "oauth2",
      "required": false
    }
  }
}
