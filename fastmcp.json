{
  "$schema": "https://gofastmcp.com/public/schemas/fastmcp.json/v1.json",
  "source": {
    "type": "filesystem",
    "path": "arifos_aaa_mcp/server.py",
    "entrypoint": "mcp"
  },
  "environment": {
    "type": "uv",
    "python": ">=3.12",
    "dependencies": ["fastmcp==3.0.2", "arifos"],
    "editable": ["."]
  },
  "deployment": {
    "transport": "http",
    "host": "${HOST:-0.0.0.0}",
    "port": 8080,
    "path": "/mcp/",
    "log_level": "INFO",
    "env": {
      "HOST": "${HOST:-0.0.0.0}",
      "PORT": "${PORT:-8080}",
      "ARIFOS_GOVERNANCE_SECRET": "${ARIFOS_GOVERNANCE_SECRET}"
    }
  }
}
