{
  "$schema": "https://gofastmcp.com/public/schemas/fastmcp.json/v1.json",
  "name": "arifos-mcp",
  "version": "2026.03.09-SEAL",
  "description": "arifOS Constitutional AI Governance MCP Server - 10-tool APEX-G constitutional hub with VAULT999 ledger",
  "source": {
    "type": "filesystem",
    "path": "arifosmcp/runtime/server.py",
    "entrypoint": "mcp"
  },
  "environment": {
    "type": "uv",
    "python": ">=3.12",
    "dependencies": [
      "fastmcp==3.0.2",
      "fastapi>=0.115.0",
      "uvicorn>=0.32.0",
      "redis>=5.0.0",
      "anthropic>=0.39.0",
      "httpx>=0.27.0",
      "pydantic>=2.9.0"
    ],
    "editable": ["."]
  },
  "deployment": {
    "transport": "http",
    "host": "${HOST:-0.0.0.0}",
    "port": 8080,
    "path": "/mcp",
    "log_level": "INFO",
    "transports_available": ["stdio", "http", "sse"],
    "env": {
      "HOST": "${HOST:-0.0.0.0}",
      "PORT": "${PORT:-8080}"
    }
  },
  "tools": {
    "core_constitutional_stack": 10,
    "phase2_legacy_tools_enabled": true,
    "governance": true,
    "description": "10-tool core constitutional stack plus legacy external capability tools kept enabled outside the new metabolic loop"
  },
  "metadata": {
    "author": "Arif Fazil",
    "repository": "https://github.com/ariffazil/arifosmcp",
    "documentation": "https://github.com/ariffazil/arifOS",
    "trinity": {
      "role": "body",
      "mind": "https://github.com/ariffazil/arifOS",
      "heart": "https://github.com/ariffazil/ariffazil"
    }
  }
}
