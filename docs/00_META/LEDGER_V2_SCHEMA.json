{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Cooling Ledger v2 Schema",
  "description": "The immutable ancestry tree and cryptographic ledger for the arifOS Double Helix.",
  "type": "object",
  "properties": {
    "entry_id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique identifier for this ledger entry."
    },
    "session_id": {
      "type": "string",
      "description": "The normalized session identity nonce."
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO-8601 timestamp of the seal event."
    },
    "parent_hash": {
      "type": "string",
      "description": "SHA-256 hash of the preceding entry in the ledger, forming the unbroken chain."
    },
    "content_hash": {
      "type": "string",
      "description": "SHA-256 hash of the payload and evidence."
    },
    "merkle_root": {
      "type": "string",
      "description": "The current root of the VAULT999 Merkle tree at the time of this entry."
    },
    "trinity_scores": {
      "type": "object",
      "properties": {
        "delta_s": {
          "type": "number",
          "description": "Entropy delta (must be <= 0 for F4 compliance)."
        },
        "omega_0": {
          "type": "number",
          "description": "Humility band score (target: [0.03, 0.05])."
        },
        "psi_g": {
          "type": "number",
          "description": "Genius score calculation (must be >= 0.80)."
        }
      },
      "required": ["delta_s", "omega_0", "psi_g"]
    },
    "floor_compliance": {
      "type": "object",
      "patternProperties": {
        "^F[1-9]|F1[0-3]$": {
          "type": "boolean"
        }
      },
      "description": "Map of F1-F13 floor pass/fail states."
    },
    "apex_prime_audit": {
      "type": "object",
      "properties": {
        "w4_score": {
          "type": "number",
          "description": "Tri-Witness Consensus Reality Test Score."
        },
        "sii_score": {
          "type": "number",
          "description": "Sovereign Integrity Index."
        },
        "status": {
          "type": "string",
          "enum": ["OK", "DEGRADED", "HALTED"]
        }
      },
      "required": ["w4_score", "sii_score", "status"]
    },
    "verdict": {
      "type": "string",
      "enum": ["SEAL", "PARTIAL", "SABAR", "VOID", "888_HOLD"],
      "description": "The final sovereign judgment from APEX."
    },
    "signature": {
      "type": "string",
      "description": "ECDSA signature of the entry_hash by the APEX_JUDGE."
    }
  },
  "required": [
    "entry_id",
    "session_id",
    "timestamp",
    "parent_hash",
    "content_hash",
    "trinity_scores",
    "verdict"
  ]
}