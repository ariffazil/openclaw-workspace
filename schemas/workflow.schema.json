{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aaa.arif-fazil.com/schemas/workflow.schema.json",
  "title": "AAA Workflow Contract",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "id": {
      "$ref": "./common.schema.json#/$defs/id"
    },
    "name": {
      "$ref": "./common.schema.json#/$defs/nonEmptyString"
    },
    "description": {
      "$ref": "./common.schema.json#/$defs/nonEmptyString"
    },
    "contract_ref": {
      "$ref": "./common.schema.json#/$defs/id"
    },
    "target_domain_plane": {
      "$ref": "./common.schema.json#/$defs/domainPlane"
    },
    "requires_domain_contract": {
      "type": "boolean"
    },
    "execution_bridge": {
      "type": "string",
      "enum": [
        "none",
        "arifos.forge"
      ]
    },
    "risk_tier": {
      "$ref": "./common.schema.json#/$defs/riskTier"
    },
    "knowledge_basis": {
      "$ref": "./common.schema.json#/$defs/knowledgeBasis"
    },
    "required_witnesses": {
      "type": "array",
      "items": {
        "$ref": "./common.schema.json#/$defs/witness"
      },
      "uniqueItems": true
    },
    "requires_arifos_judgment": {
      "type": "boolean"
    },
    "requires_vault_seal": {
      "type": "boolean"
    },
    "separation_of_duties": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "proposer_must_differ_from_approver": {
          "type": "boolean"
        }
      },
      "required": [
        "proposer_must_differ_from_approver"
      ]
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "id": {
            "$ref": "./common.schema.json#/$defs/id"
          },
          "title": {
            "$ref": "./common.schema.json#/$defs/nonEmptyString"
          },
          "stage": {
            "$ref": "./common.schema.json#/$defs/pipelineStage"
          },
          "role": {
            "$ref": "./common.schema.json#/$defs/role"
          },
          "agent_ref": {
            "$ref": "./common.schema.json#/$defs/id"
          },
          "required_skills": {
            "$ref": "./common.schema.json#/$defs/stringIdArray"
          },
          "required_tools": {
            "$ref": "./common.schema.json#/$defs/stringIdArray"
          },
          "required_servers": {
            "$ref": "./common.schema.json#/$defs/stringIdArray"
          },
          "holds": {
            "type": "array",
            "items": {
              "$ref": "./common.schema.json#/$defs/approvalRecord"
            }
          },
          "inputs": {
            "type": "array",
            "items": {
              "$ref": "./common.schema.json#/$defs/nonEmptyString"
            }
          },
          "outputs": {
            "type": "array",
            "items": {
              "$ref": "./common.schema.json#/$defs/nonEmptyString"
            }
          },
          "on_error": {
            "type": "string",
            "enum": [
              "halt",
              "retry",
              "rollback",
              "escalate"
            ]
          },
          "retry_policy": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "max_attempts": {
                "type": "integer",
                "minimum": 0
              },
              "backoff": {
                "type": "string",
                "enum": [
                  "none",
                  "fixed",
                  "exponential"
                ]
              }
            },
            "required": [
              "max_attempts",
              "backoff"
            ]
          }
        },
        "required": [
          "id",
          "title",
          "stage",
          "role",
          "required_skills",
          "required_tools",
          "required_servers",
          "holds",
          "inputs",
          "outputs",
          "on_error",
          "retry_policy"
        ]
      }
    }
  },
  "required": [
    "id",
    "name",
    "description",
    "contract_ref",
    "risk_tier",
    "knowledge_basis",
    "required_witnesses",
    "requires_arifos_judgment",
    "requires_vault_seal",
    "separation_of_duties",
    "steps"
  ],
  "allOf": [
    {
      "if": {
        "properties": {
          "risk_tier": {
            "enum": [
              "high",
              "critical"
            ]
          }
        },
        "required": [
          "risk_tier"
        ]
      },
      "then": {
        "properties": {
          "requires_arifos_judgment": {
            "const": true
          },
          "requires_vault_seal": {
            "const": true
          },
          "separation_of_duties": {
            "properties": {
              "proposer_must_differ_from_approver": {
                "const": true
              }
            }
          },
          "steps": {
            "contains": {
              "type": "object",
              "properties": {
                "stage": {
                  "const": "888"
                },
                "role": {
                  "const": "auditor"
                }
              },
              "required": [
                "stage",
                "role"
              ]
            }
          }
        }
      }
    }
  ]
}
