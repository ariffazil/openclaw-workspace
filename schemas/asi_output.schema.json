{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "arifos://schemas/asi_output.schema.json",
  "title": "ASI Output (Stages 444-666)",
  "description": "Output contract for the ASI Heart Engine. Returns empathy metrics, safety scores, and alignment verdict.",
  "type": "object",
  "required": ["session_id", "vote", "verdict", "empathy_kappa_r", "peace_squared"],
  "properties": {
    "session_id": {
      "type": "string",
      "description": "Session identifier"
    },
    "omega_total": {
      "type": "number",
      "description": "Total thermodynamic burden (Ω) calculated across all stakeholders",
      "minimum": 0
    },
    "vote": {
      "type": "string",
      "enum": ["SEAL", "VOID", "SABAR", "888_HOLD"],
      "description": "ASI's vote on the proposal"
    },
    "verdict": {
      "type": "string",
      "enum": ["SEAL", "VOID", "SABAR", "888_HOLD"],
      "description": "ASI's verdict (same as vote, for consistency)"
    },
    "empathy_kappa_r": {
      "type": "number",
      "description": "Empathy coefficient (κᵣ) measuring care for weakest stakeholder",
      "minimum": 0,
      "maximum": 1
    },
    "peace_squared": {
      "type": "number",
      "description": "Peace metric (Peace²) measuring non-destructive nature",
      "minimum": 0
    },
    "thermodynamic_justice": {
      "type": "number",
      "description": "Justice score based on thermodynamic principles",
      "minimum": 0,
      "maximum": 1
    },
    "stakeholders": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {"type": "string"},
          "vulnerability": {"type": "number", "minimum": 0, "maximum": 1},
          "impact": {"type": "number"}
        }
      },
      "description": "List of identified stakeholders with impact analysis"
    },
    "weakest_stakeholder": {
      "type": "object",
      "properties": {
        "id": {"type": "string"},
        "vulnerability": {"type": "number"},
        "impact": {"type": "number"}
      },
      "description": "The most vulnerable stakeholder (F6 Empathy focus)"
    },
    "reversibility_score": {
      "type": "number",
      "description": "F1 Amanah score (1.0 = fully reversible)",
      "minimum": 0,
      "maximum": 1
    },
    "consent_verified": {
      "type": "boolean",
      "description": "F11 Command Authority - consent verified"
    }
  },
  "additionalProperties": true
}
