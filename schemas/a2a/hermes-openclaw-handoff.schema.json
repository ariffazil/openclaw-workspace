{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Hermes ↔ OpenClaw A2A Handoff Contract",
  "description": "Message envelope for federation coordination between Hermes ASI and OpenClaw operator",
  "type": "object",
  "required": ["protocol", "from", "to", "task", "telemetry"],
  "properties": {
    "protocol": {
      "const": "A2A"
    },
    "from": {
      "type": "string",
      "enum": ["hermes", "openclaw"]
    },
    "to": {
      "type": "string",
      "enum": ["hermes", "openclaw"]
    },
    "task": {
      "type": "object",
      "required": ["operation"],
      "properties": {
        "operation": {
          "type": "string"
        },
        "target": {
          "type": "string"
        },
        "priority": {
          "type": "string",
          "enum": ["low", "normal", "high", "critical"]
        }
      }
    },
    "context": {
      "type": "object",
      "properties": {
        "human_requestor": {
          "type": "string"
        },
        "session_id": {
          "type": "string"
        },
        "correlation_id": {
          "type": "string",
          "format": "uuid"
        }
      }
    },
    "result": {
      "type": "object",
      "properties": {
        "status": {
          "type": "string",
          "enum": ["completed", "failed", "pending", "hold"]
        },
        "summary": {
          "type": "string"
        },
        "details": {
          "type": "object"
        }
      }
    },
    "telemetry": {
      "type": "object",
      "required": ["epoch"],
      "properties": {
        "epoch": {
          "type": "string",
          "format": "date-time"
        },
        "constitutional_floor": {
          "type": "string",
          "pattern": "^F(0[1-9]|1[0-3])$"
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "execution_time_ms": {
          "type": "integer",
          "minimum": 0
        },
        "verdict": {
          "type": "string"
        }
      }
    }
  }
}
