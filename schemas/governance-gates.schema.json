{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aaa.arif-fazil.com/schemas/governance-gates.schema.json",
  "title": "AAA Governance Gates Contract",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "version": { "type": "integer", "minimum": 1 },
    "id": { "$ref": "./common.schema.json#/$defs/id" },
    "name": { "$ref": "./common.schema.json#/$defs/nonEmptyString" },
    "stage_band": { "const": "666-777" },
    "domain_plane": { "$ref": "./common.schema.json#/$defs/domainPlane" },
    "purpose": { "$ref": "./common.schema.json#/$defs/nonEmptyString" },
    "governance_gates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "id": { "$ref": "./common.schema.json#/$defs/id" },
          "title": { "$ref": "./common.schema.json#/$defs/nonEmptyString" },
          "goal_ref": { "$ref": "./common.schema.json#/$defs/id" },
          "owner_org_unit": { "$ref": "./common.schema.json#/$defs/id" },
          "workflow_ref": { "$ref": "./common.schema.json#/$defs/id" },
          "budget_policy_ref": { "$ref": "./common.schema.json#/$defs/id" },
          "required_roles": {
            "type": "array",
            "items": { "$ref": "./common.schema.json#/$defs/role" },
            "minItems": 1,
            "uniqueItems": true
          },
          "approval_policy": { "$ref": "./common.schema.json#/$defs/approvalPolicy" },
          "trigger_conditions": {
            "type": "array",
            "items": { "$ref": "./common.schema.json#/$defs/nonEmptyString" },
            "minItems": 1
          },
          "evidence_inputs": {
            "type": "array",
            "items": { "$ref": "./common.schema.json#/$defs/nonEmptyString" },
            "minItems": 1
          },
          "decision_outputs": {
            "type": "array",
            "items": { "$ref": "./common.schema.json#/$defs/nonEmptyString" },
            "minItems": 1
          },
          "cost_estimate_required": { "type": "boolean" },
          "weakest_stakeholder": { "$ref": "./common.schema.json#/$defs/nonEmptyString" },
          "status": {
            "type": "string",
            "enum": ["pending", "active", "hold", "retired"]
          }
        },
        "required": [
          "id",
          "title",
          "goal_ref",
          "owner_org_unit",
          "workflow_ref",
          "budget_policy_ref",
          "required_roles",
          "approval_policy",
          "trigger_conditions",
          "evidence_inputs",
          "decision_outputs",
          "cost_estimate_required",
          "weakest_stakeholder",
          "status"
        ]
      }
    },
    "budgets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "id": { "$ref": "./common.schema.json#/$defs/id" },
          "scope_type": {
            "type": "string",
            "enum": ["org-unit", "agent"]
          },
          "scope_ref": { "$ref": "./common.schema.json#/$defs/id" },
          "unit": {
            "type": "string",
            "enum": ["usd", "tokens", "compute-minutes"]
          },
          "limit": { "type": "number", "exclusiveMinimum": 0 },
          "warning_threshold": { "type": "number", "exclusiveMinimum": 0, "maximum": 1 },
          "hard_stop_threshold": { "type": "number", "exclusiveMinimum": 0, "maximum": 1 },
          "reset_period": {
            "type": "string",
            "enum": ["daily", "weekly", "monthly"]
          },
          "applies_to_agents": { "$ref": "./common.schema.json#/$defs/stringIdArray" },
          "enforcement_mode": { "$ref": "./common.schema.json#/$defs/approvalPolicy" }
        },
        "required": [
          "id",
          "scope_type",
          "scope_ref",
          "unit",
          "limit",
          "warning_threshold",
          "hard_stop_threshold",
          "reset_period",
          "applies_to_agents",
          "enforcement_mode"
        ]
      }
    }
  },
  "required": [
    "version",
    "id",
    "name",
    "stage_band",
    "domain_plane",
    "purpose",
    "governance_gates",
    "budgets"
  ]
}
