{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "arifos://schemas/vault_output.schema.json",
  "title": "Vault Seal Output (Stage 999)",
  "description": "Output contract for VAULT-999 sealing with EUREKA filtering and cryptographic proofs.",
  "type": "object",
  "required": ["operation", "verdict"],
  "properties": {
    "operation": {
      "type": "string",
      "enum": ["sealed", "cooling", "transient", "list", "read", "query", "verify", "proof", "error"],
      "description": "Type of vault operation performed"
    },
    "verdict": {
      "type": "string",
      "enum": ["SEAL", "VOID", "SABAR", "TRANSIENT"],
      "description": "EUREKA-filtered verdict"
    },
    "session_id": {
      "type": "string",
      "description": "Session identifier"
    },
    "sealed": {
      "type": "object",
      "properties": {
        "session_id": {"type": "string"},
        "seal_id": {"type": "string"},
        "entry_hash": {"type": "string"},
        "merkle_root": {"type": "string"},
        "sequence": {"type": "integer"},
        "timestamp": {"type": "string", "format": "date-time"}
      },
      "description": "Seal receipt (only for operation='sealed')"
    },
    "vault_backend": {
      "type": "string",
      "enum": ["postgres", "filesystem"],
      "description": "Which backend was used for storage"
    },
    "eureka": {
      "type": "object",
      "properties": {
        "eureka_score": {"type": "number", "minimum": 0, "maximum": 1},
        "novelty": {"type": "number"},
        "entropy_reduction": {"type": "number"},
        "ontological_shift": {"type": "number"},
        "decision_weight": {"type": "number"},
        "verdict": {"type": "string", "enum": ["TRANSIENT", "SABAR", "SEAL"]},
        "reasoning": {"type": "array", "items": {"type": "string"}},
        "fingerprint": {"type": "string"}
      },
      "description": "EUREKA Sieve evaluation metadata"
    },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "session_id": {"type": "string"},
          "verdict": {"type": "string"},
          "timestamp": {"type": "string"},
          "entry_hash": {"type": "string"}
        }
      },
      "description": "List of entries (for list/query operations)"
    },
    "entry": {
      "type": "object",
      "description": "Single entry details (for read operation)"
    },
    "count": {
      "type": "integer",
      "description": "Number of entries returned"
    },
    "valid": {
      "type": "boolean",
      "description": "Chain validity (for verify operation)"
    },
    "merkle_root": {
      "type": "string",
      "description": "Root hash of Merkle tree"
    },
    "reason": {
      "type": "string",
      "description": "Explanation for the operation result"
    },
    "message": {
      "type": "string",
      "description": "Human-readable status message"
    },
    "authority_notice": {
      "type": "string",
      "description": "Required authority disclaimer"
    }
  },
  "additionalProperties": true
}
