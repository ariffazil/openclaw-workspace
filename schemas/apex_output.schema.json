{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "arifos://schemas/apex_output.schema.json",
  "title": "APEX Output (Stages 777-888)",
  "description": "Output contract for the APEX Soul Engine. Returns final constitutional verdict with cryptographic proof.",
  "type": "object",
  "required": ["session_id", "final_verdict", "verdict", "trinity_score"],
  "properties": {
    "session_id": {
      "type": "string",
      "description": "Session identifier"
    },
    "final_verdict": {
      "type": "string",
      "enum": ["SEAL", "VOID", "SABAR", "888_HOLD", "PARTIAL"],
      "description": "Final constitutional verdict"
    },
    "verdict": {
      "type": "string",
      "enum": ["SEAL", "VOID", "SABAR", "888_HOLD", "PARTIAL"],
      "description": "Same as final_verdict, for consistency"
    },
    "trinity_score": {
      "type": "number",
      "description": "Tri-Witness consensus score (geometric mean of Human × AI × System)",
      "minimum": 0,
      "maximum": 1
    },
    "paradox_scores": {
      "type": "object",
      "description": "Scores for each of the 8 paradoxes evaluated",
      "additionalProperties": {"type": "number"}
    },
    "equilibrium": {
      "type": "object",
      "properties": {
        "score": {"type": "number"},
        "delta": {"type": "number"},
        "stable": {"type": "boolean"}
      },
      "description": "Thermodynamic equilibrium state"
    },
    "constitutional_alignment": {
      "type": "object",
      "properties": {
        "f1_amanah": {"type": "boolean"},
        "f2_truth": {"type": "number"},
        "f3_tri_witness": {"type": "number"},
        "f4_clarity": {"type": "number"},
        "f5_peace": {"type": "number"},
        "f6_empathy": {"type": "number"},
        "f7_humility": {"type": "number"},
        "f8_genius": {"type": "number"},
        "f9_anti_hantu": {"type": "boolean"},
        "f10_ontology": {"type": "boolean"},
        "f11_authority": {"type": "boolean"},
        "f12_injection": {"type": "number"},
        "f13_sovereign": {"type": "boolean"}
      },
      "description": "Per-floor constitutional compliance scores"
    },
    "proof": {
      "type": "object",
      "properties": {
        "merkle_root": {"type": "string"},
        "signature": {"type": "string"},
        "timestamp": {"type": "string", "format": "date-time"},
        "schema_version": {"type": "string"}
      },
      "description": "Cryptographic proof of constitutional validation"
    }
  },
  "additionalProperties": true
}
