{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Federation Memory Broker Telemetry Schema",
  "description": "Telemetry written to Redis by federation-memory-broker plugin. Polls Hermes state.db every 60s.",
  "type": "object",
  "required": ["timestamp", "agent_id", "active_sessions", "message_count_24h", "error_rate_24h"],
  "properties": {
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "agent_id": {
      "type": "string",
      "enum": ["hermes", "openclaw", "maxhermes"]
    },
    "active_sessions": {
      "type": "integer",
      "minimum": 0
    },
    "message_count_24h": {
      "type": "integer",
      "minimum": 0
    },
    "error_rate_24h": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "token_usage_24h": {
      "type": "integer",
      "minimum": 0
    },
    "tool_calls_24h": {
      "type": "object",
      "additionalProperties": {
        "type": "integer",
        "minimum": 0
      }
    },
    "mode_distribution": {
      "type": "object",
      "properties": {
        "PERSONAL": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "ASK": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "AGENTIC": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "avg_response_time_ms": {
      "type": "integer",
      "minimum": 0
    },
    "pending_holds": {
      "type": "integer",
      "minimum": 0
    }
  }
}
