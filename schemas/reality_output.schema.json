{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "arifos://schemas/reality_output.schema.json",
  "title": "Reality Check Output (External Grounding)",
  "description": "Output contract for external fact-checking and reality grounding (F2 Truth enforcement).",
  "type": "object",
  "required": ["status", "verdict"],
  "properties": {
    "status": {
      "type": "string",
      "enum": ["SEAL", "VOID", "SABAR", "ERROR"],
      "description": "Operation status"
    },
    "verdict": {
      "type": "string",
      "enum": ["SEAL", "VOID", "SABAR"],
      "description": "Grounding verdict - SEAL if facts verified, SABAR if uncertain, VOID if disproven"
    },
    "query": {
      "type": "string",
      "description": "The fact-checking query that was submitted"
    },
    "session_id": {
      "type": "string",
      "description": "Session identifier"
    },
    "source": {
      "type": "string",
      "description": "Primary source of ground truth (e.g., 'brave_search', 'perplexity', 'cache')"
    },
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {"type": "string"},
          "url": {"type": "string", "format": "uri"},
          "credibility": {"type": "number", "minimum": 0, "maximum": 1},
          "timestamp": {"type": "string", "format": "date-time"}
        }
      },
      "description": "List of sources consulted for fact-checking"
    },
    "evidence": {
      "type": "array",
      "items": {"type": "string"},
      "description": "Evidence snippets supporting the grounding"
    },
    "confidence": {
      "type": "number",
      "description": "Confidence score in the grounding (0-1)",
      "minimum": 0,
      "maximum": 1
    },
    "reason": {
      "type": "string",
      "description": "Explanation for the verdict"
    },
    "fallback_guidance": {
      "type": "string",
      "description": "Guidance for agent when external sensors fail (Meta-Atlas Protocol)"
    },
    "error": {
      "type": "object",
      "properties": {
        "message": {"type": "string"},
        "code": {"type": "string"},
        "suggestion": {"type": "string"}
      },
      "description": "Error details if status is ERROR"
    }
  },
  "additionalProperties": true
}
