{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aaa.arif-fazil.com/schemas/org-topology.schema.json",
  "title": "AAA Org Topology Contract",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "id": {
      "$ref": "./common.schema.json#/$defs/id"
    },
    "name": {
      "$ref": "./common.schema.json#/$defs/nonEmptyString"
    },
    "stage": {
      "const": "333"
    },
    "domain_plane": {
      "$ref": "./common.schema.json#/$defs/domainPlane"
    },
    "purpose": {
      "$ref": "./common.schema.json#/$defs/nonEmptyString"
    },
    "org_units": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "id": { "$ref": "./common.schema.json#/$defs/id" },
          "name": { "$ref": "./common.schema.json#/$defs/nonEmptyString" },
          "type": {
            "type": "string",
            "enum": ["control-plane", "upstream-law", "witness", "squad", "council", "cell"]
          },
          "parent_org_unit": {
            "type": ["string", "null"],
            "pattern": "^[a-z0-9]+(?:[-_][a-z0-9]+)*$"
          },
          "trust_tier": {
            "type": "string",
            "enum": ["internal", "federated", "infrastructure"]
          },
          "lead_agent": {
            "type": ["string", "null"],
            "pattern": "^[a-z0-9]+(?:[-_][a-z0-9]+)*$"
          },
          "members": { "$ref": "./common.schema.json#/$defs/stringIdArray" },
          "owned_domain_planes": {
            "type": "array",
            "items": { "$ref": "./common.schema.json#/$defs/domainPlane" },
            "minItems": 1,
            "uniqueItems": true
          },
          "workflow_scope": { "$ref": "./common.schema.json#/$defs/stringIdArray" },
          "notes": { "$ref": "./common.schema.json#/$defs/nonEmptyString" }
        },
        "required": [
          "id",
          "name",
          "type",
          "parent_org_unit",
          "trust_tier",
          "lead_agent",
          "members",
          "owned_domain_planes",
          "workflow_scope",
          "notes"
        ]
      }
    },
    "topology_edges": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "id": { "$ref": "./common.schema.json#/$defs/id" },
          "from_org_unit": { "$ref": "./common.schema.json#/$defs/id" },
          "to_org_unit": { "$ref": "./common.schema.json#/$defs/id" },
          "relation": {
            "type": "string",
            "enum": ["delegates-to", "governed-by", "reports-to", "supports"]
          },
          "workflow_refs": { "$ref": "./common.schema.json#/$defs/stringIdArray" },
          "trust_tier": {
            "type": "string",
            "enum": ["internal", "federated", "infrastructure"]
          },
          "rationale": { "$ref": "./common.schema.json#/$defs/nonEmptyString" }
        },
        "required": [
          "id",
          "from_org_unit",
          "to_org_unit",
          "relation",
          "workflow_refs",
          "trust_tier",
          "rationale"
        ]
      }
    }
  },
  "required": [
    "version",
    "id",
    "name",
    "stage",
    "domain_plane",
    "purpose",
    "org_units",
    "topology_edges"
  ]
}
