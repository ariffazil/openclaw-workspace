{
  "_schema": "arifOS Constitutional Agent Configuration v1.0",
  "_description": "5 specialized agents following arifOS Constitutional AI principles",
  "agents": {
    "list": [
      {
        "id": "a-architect",
        "name": "A-ARCHITECT",
        "description": "Constitutional System Architect - Δ (Delta) AGI Mind",
        "emoji": "🏛️",
        "motto": "Structure precedes function",
        "role": "Design Authority",
        "trinity": "Δ",
        "workspace": "~/.openclaw/workspace/agents/a-architect",
        "agentDir": "~/.openclaw/agents/a-architect",
        "model": {
          "primary": "kimi-coding/k2p5",
          "fallbacks": [
            "anthropic/claude-sonnet-4-5",
            "google/gemini-2.5-flash",
            "ollama/qwen2.5:3b"
          ]
        },
        "tools": {
          "profile": "full",
          "allowed": ["read", "write", "shell", "web"]
        },
        "bootFiles": [
          "AGENTS.md",
          "docs/VPS_ARCHITECTURE_MASTER_DOSSIER.md",
          "core/shared/floors.py"
        ],
        "compaction": {
          "memoryFlush": {
            "enabled": true,
            "softThresholdTokens": 4000
          }
        },
        "heartbeat": {
          "enabled": false
        }
      },
      {
        "id": "a-engineer",
        "name": "A-ENGINEER",
        "description": "Constitutional Implementation Engineer - Ω (Omega) ASI Heart",
        "emoji": "⚙️",
        "motto": "Working code is the only truth",
        "role": "Execution Authority",
        "trinity": "Ω",
        "workspace": "~/.openclaw/workspace/agents/a-engineer",
        "agentDir": "~/.openclaw/agents/a-engineer",
        "model": {
          "primary": "kimi-coding/k2p5",
          "fallbacks": [
            "anthropic/claude-sonnet-4-5",
            "google/gemini-2.5-flash",
            "google/gemini-3-flash-preview"
          ]
        },
        "tools": {
          "profile": "full",
          "allowed": ["read", "write", "shell", "web", "exec"]
        },
        "bootFiles": [
          "AGENTS.md",
          "pyproject.toml",
          "tests/conftest.py",
          "core/shared/floors.py"
        ],
        "compaction": {
          "memoryFlush": {
            "enabled": true,
            "softThresholdTokens": 4000
          }
        },
        "heartbeat": {
          "enabled": false
        }
      },
      {
        "id": "a-auditor",
        "name": "A-AUDITOR",
        "description": "Constitutional Quality & Compliance Auditor - Ψ (Psi) APEX Soul",
        "emoji": "🔍",
        "motto": "Trust but verify, always",
        "role": "Judgment Authority",
        "trinity": "Ψ",
        "workspace": "~/.openclaw/workspace/agents/a-auditor",
        "agentDir": "~/.openclaw/agents/a-auditor",
        "model": {
          "primary": "kimi-coding/k2p5",
          "fallbacks": [
            "anthropic/claude-sonnet-4-5",
            "google/gemini-2.5-flash",
            "ollama/qwen2.5:3b"
          ]
        },
        "tools": {
          "profile": "full",
          "allowed": ["read", "shell", "web"]
        },
        "bootFiles": [
          "core/shared/floors.py",
          "AGENTS.md",
          ".github/copilot-instructions.md"
        ],
        "compaction": {
          "memoryFlush": {
            "enabled": true,
            "softThresholdTokens": 4000
          }
        },
        "heartbeat": {
          "enabled": false
        }
      },
      {
        "id": "a-orchestrator",
        "name": "A-ORCHESTRATOR",
        "description": "Constitutional Workflow Coordinator - ΔΩΨ (Trinity) Integration",
        "emoji": "🎼",
        "motto": "The whole is greater than the sum of parts",
        "role": "Coordination Authority",
        "trinity": "ΔΩΨ",
        "workspace": "~/.openclaw/workspace/agents/a-orchestrator",
        "agentDir": "~/.openclaw/agents/a-orchestrator",
        "model": {
          "primary": "kimi-coding/k2p5",
          "fallbacks": [
            "anthropic/claude-sonnet-4-5",
            "google/gemini-2.5-flash",
            "ollama/qwen2.5:3b"
          ]
        },
        "tools": {
          "profile": "full",
          "allowed": ["read", "write", "shell", "web", "sessions_spawn"]
        },
        "bootFiles": [
          "AGENTS/agents/",
          "docs/VPS_ARCHITECTURE_MASTER_DOSSIER.md"
        ],
        "compaction": {
          "memoryFlush": {
            "enabled": true,
            "softThresholdTokens": 4000
          }
        },
        "heartbeat": {
          "enabled": true,
          "every": "60m",
          "target": "last",
          "model": "google/gemini-2.5-flash"
        }
      },
      {
        "id": "a-validator",
        "name": "A-VALIDATOR",
        "description": "Constitutional Verification & Testing Authority - Ψ (Psi) Final Judgment",
        "emoji": "✓",
        "motto": "Prove it works, or it doesn't work",
        "role": "Final Verification Authority",
        "trinity": "Ψ",
        "workspace": "~/.openclaw/workspace/agents/a-validator",
        "agentDir": "~/.openclaw/agents/a-validator",
        "model": {
          "primary": "kimi-coding/k2p5",
          "fallbacks": [
            "anthropic/claude-sonnet-4-5",
            "google/gemini-2.5-flash",
            "ollama/qwen2.5:3b"
          ]
        },
        "tools": {
          "profile": "full",
          "allowed": ["read", "shell", "exec", "web"]
        },
        "bootFiles": [
          "tests/",
          "core/shared/floors.py",
          "AGENTS.md"
        ],
        "compaction": {
          "memoryFlush": {
            "enabled": true,
            "softThresholdTokens": 4000
          }
        },
        "heartbeat": {
          "enabled": false
        }
      }
    ]
  },
  "trinity_workflows": {
    "standard_development": {
      "description": "Design → Implement → Review → Validate",
      "flow": [
        {"agent": "a-architect", "phase": "design", "output": "architecture_spec"},
        {"agent": "a-engineer", "phase": "implement", "input": "architecture_spec", "output": "implementation"},
        {"agent": "a-auditor", "phase": "review", "input": "implementation", "output": "audit_report"},
        {"agent": "a-validator", "phase": "validate", "input": "implementation", "output": "seal_or_void"}
      ],
      "orchestrator": "a-orchestrator"
    },
    "hotfix": {
      "description": "Emergency fix with minimal process",
      "flow": [
        {"agent": "a-engineer", "phase": "implement", "output": "fix"},
        {"agent": "a-validator", "phase": "validate", "input": "fix", "output": "seal_or_void"}
      ],
      "orchestrator": "a-orchestrator",
      "note": "Skips architect/auditor for emergencies only"
    },
    "audit_only": {
      "description": "Review existing code without changes",
      "flow": [
        {"agent": "a-auditor", "phase": "review", "output": "audit_report"}
      ]
    }
  },
  "communication_protocol": {
    "invocation": "@{agent-id} [task description]",
    "handoff": "@{next-agent} Continue: [context summary]",
    "escalation": "@human [issue] requires override",
    "status": "/status to check agent health and context"
  },
  "cost_optimization": {
    "note": "All agents use k2p5 primary with cheap fallbacks",
    "heartbeat_strategy": "Only orchestrator runs heartbeats (cheap model)",
    "batching": "Group related tasks to minimize context switches",
    "delegation": "Use sessions_spawn for parallel sub-agent work"
  }
}
