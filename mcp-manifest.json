{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.ariffazil/arifos-mcp",
  "version": "2026.3.1",
  "title": "arifOS Sovereign Governance MCP",
  "description": "Constitutional AI governance server with 13-tool surface, Trinity engines (ΔΩΨ), and F1-F13 floor enforcement.",
  "websiteUrl": "https://arifos.arif-fazil.com/",
  "vendor": {
    "name": "arifOS",
    "url": "https://arifos.arif-fazil.com"
  },
  "license": "AGPL-3.0-only",
  "repository": {
    "url": "https://github.com/ariffazil/arifOS",
    "source": "github"
  },
  "runtime": {
    "python": ">=3.12",
    "entrypoint": "python -m arifos_aaa_mcp",
    "dependencies": ["fastmcp==3.0.2"]
  },
  "deployment": {
    "default_transport": "http",
    "host": "0.0.0.0",
    "port": 8080,
    "path": "/mcp",
    "log_level": "INFO"
  },
  "packages": [
    {
      "registryType": "pypi",
      "identifier": "arifos",
      "version": "2026.3.1",
      "transport": { "type": "stdio" }
    },
    {
      "registryType": "oci",
      "identifier": "docker.io/arifazil/arifosmcp:forge-777",
      "transport": {
        "type": "streamable-http",
        "url": "https://arifosmcp.arif-fazil.com/mcp"
      }
    }
  ],
  "remotes": [
    {
      "name": "jina-reader",
      "type": "remote",
      "url": "https://mcp.jina.ai/v1",
      "headers": { "Authorization": "Bearer ${JINA_API_KEY}" }
    },
    {
      "name": "context7",
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": { "Authorization": "Bearer ${CONTEXT7_API_KEY}" }
    },
    {
      "type": "sse",
      "url": "https://arifosmcp.arif-fazil.com/sse"
    },
    {
      "type": "streamable-http",
      "url": "https://arifosmcp.arif-fazil.com/mcp",
      "authentication": { "type": "none" }
    }
  ],
  "tools": {
    "anchor_session": {
      "stage": "000",
      "trinity": "Δ Delta",
      "floors": ["F11", "F12", "F13"],
      "description": "Session ignition & injection defense"
    },
    "reason_mind": {
      "stage": "333",
      "trinity": "Δ Delta",
      "floors": ["F2", "F4", "F7", "F8"],
      "description": "AGI cognition & logic grounding"
    },
    "vector_memory": {
      "stage": "444",
      "trinity": "Ω Omega",
      "floors": ["F4", "F7", "F13"],
      "description": "Associative memory traces via EUREKA sieve"
    },
    "simulate_heart": {
      "stage": "555",
      "trinity": "Ω Omega",
      "floors": ["F4", "F5", "F6"],
      "description": "Stakeholder impact & care constraints"
    },
    "critique_thought": {
      "stage": "666",
      "trinity": "Ω Omega",
      "floors": ["F4", "F7", "F8"],
      "description": "7-model bias critique & alignment check"
    },
    "apex_judge": {
      "stage": "888",
      "trinity": "Ψ Psi",
      "floors": ["F1-F13"],
      "description": "Sovereign verdict synthesis + governance_token"
    },
    "eureka_forge": {
      "stage": "777",
      "trinity": "Ψ Psi",
      "floors": ["F1", "F11", "F12"],
      "description": "Sandboxed action execution with risk classification"
    },
    "seal_vault": {
      "stage": "999",
      "trinity": "Ψ Psi",
      "floors": ["F1", "F3", "F10"],
      "description": "Immutable ledger persistence (token-locked)"
    },
    "search_reality": {
      "stage": "111",
      "trinity": "Δ Delta",
      "floors": ["F2", "F4", "F12"],
      "description": "Web grounding (Perplexity/Brave)",
      "readonly": true
    },
    "ingest_evidence": {
      "stage": "111",
      "trinity": "Δ Delta",
      "floors": ["F1", "F2", "F4", "F11", "F12"],
      "description": "Content retrieval & filesystem inspection (URL/file)",
      "readonly": true
    },
    "metabolic_loop": {
      "stage": "000-999",
      "trinity": "ALL",
      "floors": ["F1-F13"],
      "description": "The arifOS Sovereign Kernel loop. Mandatory safety wrapper."
    },
    "audit_rules": {
      "stage": "333",
      "trinity": "Δ Delta",
      "floors": ["F2", "F8", "F10"],
      "description": "Constitutional rule audit checks",
      "readonly": true
    },
    "check_vital": {
      "stage": "555",
      "trinity": "Ω Omega",
      "floors": ["F4", "F5", "F7"],
      "description": "System health & vital signs",
      "readonly": true
    }
  },
  "trinity": {
    "delta": { "symbol": "Δ", "name": "Mind", "role": "AGI Reasoning", "stages": ["000", "111", "333"], "floors": ["F2", "F4", "F7", "F8"] },
    "omega": { "symbol": "Ω", "name": "Heart", "role": "ASI Safety", "stages": ["444", "555", "666"], "floors": ["F5", "F6", "F9"] },
    "psi": { "symbol": "Ψ", "name": "Soul", "role": "APEX Judgment", "stages": ["777", "888", "999"], "floors": ["F1", "F10", "F11", "F12", "F13"] }
  }
}
