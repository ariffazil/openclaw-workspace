{
  "name": "arifos",
  "version": "0.1.0",
  "description": "Constitutional governance for LLMs: 13 measurable floors (truth, peace, amanah) + Human·AI·Earth tri-witness consensus. Prevents hallucination, escalation, and dark-pattern behaviour.",
  "homepage_url": "https://github.com/ariffazil/arifOS#readme",
  "license": "AGPL-3.0",
  "author": "Muhammad Arif bin Fazil",
  "tags": [
    "constitutional-ai",
    "governance",
    "safety-floors",
    "vault999",
    "arifos",
    "aaa-mcp"
  ],
  "servers": [
    {
      "id": "aaa-mcp-stdio",
      "description": "arifOS AAA MCP server over stdio (FastMCP).",
      "transport": "stdio",
      "command": "python",
      "args": ["-m", "aaa_mcp.server"]
    }
  ],
  "tools": [
    {
      "name": "init_gate",
      "description": "Initialize a constitutional session (000_INIT).",
      "input_schema": {
        "type": "object",
        "properties": {
          "query": {"type": "string", "description": "Natural-language description of the task or question."},
          "session_id": {"type": "string", "description": "Optional session id.", "nullable": true},
          "grounding_required": {"type": "boolean", "description": "Require external reality grounding.", "default": true},
          "mode": {"type": "string", "description": "Context mode: 'strict' or 'fluid'.", "default": "fluid"}
        },
        "required": ["query"]
      }
    },
    {
      "name": "agi_sense",
      "description": "Parse intent and classify lane (HARD/SOFT/META).",
      "input_schema": {
        "type": "object",
        "properties": {
          "query": {"type": "string"},
          "session_id": {"type": "string"}
        },
        "required": ["query", "session_id"]
      }
    },
    {
      "name": "agi_think",
      "description": "Generate hypotheses and explore reasoning paths.",
      "input_schema": {
        "type": "object",
        "properties": {
          "query": {"type": "string"},
          "session_id": {"type": "string"}
        },
        "required": ["query", "session_id"]
      }
    },
    {
      "name": "agi_reason",
      "description": "Deep logical reasoning chain — AGI Mind core analysis.",
      "input_schema": {
        "type": "object",
        "properties": {
          "query": {"type": "string"},
          "session_id": {"type": "string"},
          "grounding": {"description": "Optional grounding data.", "nullable": true}
        },
        "required": ["query", "session_id"]
      }
    },
    {
      "name": "asi_empathize",
      "description": "Assess stakeholder impact — the ASI Heart's empathy engine.",
      "input_schema": {
        "type": "object",
        "properties": {
          "query": {"type": "string"},
          "session_id": {"type": "string"}
        },
        "required": ["query", "session_id"]
      }
    },
    {
      "name": "asi_align",
      "description": "Reconcile ethics, law, and policy — the ASI Heart's alignment engine.",
      "input_schema": {
        "type": "object",
        "properties": {
          "query": {"type": "string"},
          "session_id": {"type": "string"}
        },
        "required": ["query", "session_id"]
      }
    },
    {
      "name": "apex_verdict",
      "description": "Final constitutional verdict — the APEX Soul's judgment (777).",
      "input_schema": {
        "type": "object",
        "properties": {
          "query": {"type": "string"},
          "session_id": {"type": "string"}
        },
        "required": ["query", "session_id"]
      }
    },
    {
      "name": "reality_search",
      "description": "External fact-checking and reality grounding via web search & Axiom Engine.",
      "input_schema": {
        "type": "object",
        "properties": {
          "query": {"type": "string"},
          "session_id": {"type": "string"},
          "region": {"type": "string", "description": "Region code, default 'wt-wt'.", "default": "wt-wt"},
          "timelimit": {"type": ["string", "null"], "description": "Optional freshness limit (e.g. 'd','w','m','y')."}
        },
        "required": ["query", "session_id"]
      }
    },
    {
      "name": "forge",
      "description": "Unified 000–999 constitutional pipeline (INIT → AGI → ASI → APEX → VAULT999).",
      "input_schema": {
        "type": "object",
        "properties": {
          "query": {"type": "string"},
          "session_id": {"type": ["string", "null"], "description": "Optional session id."},
          "mode": {"type": "string", "description": "'full' or 'agionly'.", "default": "full"}
        },
        "required": ["query"]
      }
    },
    {
      "name": "vault_seal",
      "description": "Seal the session verdict into the immutable VAULT999 ledger (999_VAULT).",
      "input_schema": {
        "type": "object",
        "properties": {
          "session_id": {"type": "string"},
          "verdict": {"type": "string"},
          "payload": {"type": "object", "description": "Full session results to record.", "additionalProperties": true},
          "query_summary": {"type": ["string", "null"]},
          "risk_level": {"type": ["string", "null"]},
          "risk_tags": {"type": ["array", "null"], "items": {"type": "string"}},
          "intent": {"type": ["string", "null"]},
          "category": {"type": ["string", "null"]},
          "floors_checked": {"type": ["array", "null"], "items": {"type": "string"}},
          "floors_passed": {"type": ["array", "null"], "items": {"type": "string"}},
          "floors_failed": {"type": ["array", "null"], "items": {"type": "string"}},
          "entropy_omega": {"type": ["number", "null"]},
          "tri_witness_score": {"type": ["number", "null"]},
          "peace_squared": {"type": ["number", "null"]},
          "genius_g": {"type": ["number", "null"]},
          "human_override": {"type": "boolean", "default": false},
          "override_reason": {"type": ["string", "null"]},
          "model_used": {"type": ["string", "null"]},
          "tags": {"type": ["array", "null"], "items": {"type": "string"}},
          "tool_chain": {"type": ["array", "null"], "items": {"type": "string"}},
          "model_info": {"type": ["object", "null"], "additionalProperties": true},
          "environment": {"type": "string", "default": "prod"},
          "prompt_excerpt": {"type": ["string", "null"]},
          "response_excerpt": {"type": ["string", "null"]},
          "pii_level": {"type": "string", "default": "none"},
          "actor_type": {"type": ["string", "null"]},
          "actor_id": {"type": ["string", "null"]}
        },
        "required": ["session_id", "verdict", "payload"]
      }
    }
  ]
}
