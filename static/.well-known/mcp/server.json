{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.ariffazil/arifos-mcp",
  "version": "2026.2.23",
  "description": "arifOS unified MCP server with SSE-primary transport, HTTP fallback at /mcp, 11 canonical tools, 2 resources, and 3 prompts.",
  "vendor": {
    "name": "arifOS",
    "url": "https://arifos.arif-fazil.com"
  },
  "license": "AGPL-3.0-only",
  "repository": {
    "url": "https://github.com/ariffazil/arifOS",
    "source": "github"
  },
  "packages": [
    {
      "registryType": "pypi",
      "identifier": "arifos",
      "version": "2026.2.23",
      "transport": {
        "type": "stdio",
        "command": "python -m aaa_mcp stdio"
      }
    },
    {
      "registryType": "oci",
      "identifier": "ghcr.io/ariffazil/arifos:latest",
      "transport": {
        "type": "sse",
        "url": "https://arifosmcp.arif-fazil.com/sse"
      }
    }
  ],
  "remotes": [
    {
      "type": "sse",
      "url": "https://arifosmcp.arif-fazil.com/sse"
    },
    {
      "type": "streamable-http",
      "url": "https://arifosmcp.arif-fazil.com/mcp"
    }
  ],
  "resources": [
    {
      "uri": "arifos://templates/full-context"
    },
    {
      "uri": "arifos://schemas/tooling"
    }
  ],
  "prompts": [
    "arifos.prompt.trinity_forge",
    "arifos.prompt.anchor_reason",
    "arifos.prompt.audit_then_seal"
  ]
}
