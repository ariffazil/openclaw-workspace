{
  "name": "arifos-aaa-mcp",
  "version": "64.1.0",
  "description": "arifOS Constitutional AI Governance MCP Server - AAA Pattern Implementation",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy:cloudflare": "wrangler deploy",
    "deploy:railway": "railway up",
    "build": "tsc",
    "test:mcp": "npx @modelcontextprotocol/inspector",
    "lint": "eslint src/**/*.ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ai-governance",
    "constitutional-ai",
    "arifos",
    "aaa-pattern",
    "oauth2"
  ],
  "author": "arifOS",
  "license": "AGPL-3.0-only",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.2.0",
    "jose": "^5.2.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250209.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0",
    "eslint": "^8.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "wrangler": "^3.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ariffazil/arifOS.git",
    "directory": "aaa_mcp"
  },
  "mcp": {
    "protocolVersion": "2025-11-25",
    "capabilities": {
      "tools": { "listChanged": true },
      "resources": {},
      "prompts": {},
      "authorization": {
        "oauth2": {
          "issuer": "${AAA_ISSUER}",
          "authorizationEndpoint": "${OAUTH_AUTHORIZATION_ENDPOINT}",
          "tokenEndpoint": "${OAUTH_TOKEN_ENDPOINT}",
          "supportsDynamicClientRegistration": true
        }
      }
    },
    "tools": [
      "init_gate",
      "trinity_forge",
      "agi_sense",
      "agi_think",
      "agi_reason",
      "asi_empathize",
      "asi_align",
      "apex_verdict",
      "reality_search",
      "vault_seal",
      "tool_router",
      "vault_query",
      "truth_audit"
    ]
  }
}
