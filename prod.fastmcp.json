{
  "$schema": "https://gofastmcp.com/public/schemas/fastmcp.json/v1.json",
  "name": "arifos-mcp",
  "version": "2026.03.07",
  "description": "arifOS Constitutional AI Governance MCP Server — prod profile (HTTP, /mcp/ path)",
