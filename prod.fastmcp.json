{
  "$schema": "https://gofastmcp.com/public/schemas/fastmcp.json/v1.json",
  "name": "arifos-constitutional-kernel-prod",
  "version": "2026.03.08",
  "description": "arifOS production profile — HTTP transport, minimal logging",

  "source": {
    "type": "filesystem",
    "path": "core/server.py",
    "entrypoint": "mcp"
  },

  "environment": {
    "type": "uv",
    "python": ">=3.12",
    "dependencies": ["fastmcp==3.0.2", "arifos"],
    "editable": ["."]
  },

  "deployment": {
    "transport": "http",
    "path": "/mcp/",
    "log_level": "WARNING",
    "env": {
      "HOST": "${HOST:-0.0.0.0}",
      "PORT": "${PORT:-8080}",
      "ARIFOS_GOVERNANCE_SECRET": "${ARIFOS_GOVERNANCE_SECRET}",
      "ARIFOS_PHYSICS_DISABLED": "0"
    }
  }
}
