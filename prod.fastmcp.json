    "type": "filesystem",
    "path": "arifos_aaa_mcp/server.py",
    "entrypoint": "mcp"
  },
  "environment": {
    "type": "uv",
    "python": ">=3.12",
    "dependencies": [
      "fastmcp==3.0.2",
      "fastapi>=0.115.0",
      "uvicorn>=0.32.0",
      "redis>=5.0.0",
      "anthropic>=0.39.0",
      "httpx>=0.27.0",
      "pydantic>=2.9.0"
    ]
  },
  "deployment": {
    "transport": "http",
    "path": "/mcp/",
    "log_level": "INFO"
  },
  "tools": {
    "count": 13,
    "governance": true,
    "description": "13 canonical tools with 13-Floor thermodynamic governance"
  },
  "metadata": {
    "author": "Arif Fazil",
    "repository": "https://github.com/ariffazil/arifosmcp",
