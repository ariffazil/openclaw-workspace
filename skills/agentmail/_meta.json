{
  "name": "agentmail",
  "description": "Give Hermes its own email inbox via AgentMail MCP",
  "version": "1.0.0",
  "tags": ["email", "communication", "agentmail", "mcp"],
  "author": "arifOS AAA",
  "license": "MIT",
  "path": "agentmail",
  "requires": {
    "api_key": "AGENTMAIL_API_KEY",
    "node_version": "18+",
    "npm_packages": ["agentmail-mcp"]
  },
  "mcp_server": {
    "command": "npx",
    "args": ["-y", "agentmail-mcp"],
    "env_var": "AGENTMAIL_API_KEY"
  }
}
