{
  "name": "arifOS KernelLoop",
  "version": "0.1.0-draft",
  "philosophy": "Ditempa Bukan Diberi — structural enforcement, not vibes",
  "based_on": "Claude Code Agent SDK loop patterns (512K leak analysis)",
  "trinity_alignment": {
    "Architect": "KernelLoop (controls loop, budgets, routing)",
    "Auditor": "888_JUDGE (watches traces, validates constitutional compliance)",
    "Agent": "MCP tool hosts (execute, stateless)"
  },

  "core_interface": {
    "description": "Standalone loop library — takes model handle, tool registry, policy object; runs full agent loop; emits structured events",
    "params": {
      "model_handle": "LLM provider (OpenRouter/minimax/Claude)",
      "tool_registry": "ToolRegistry instance",
      "policy_object": "ToolPolicyEngine instance", 
      "auditor_handle": "888_JUDGE instance for trace validation",
      "config": {
        "max_turns": 50,
        "max_cost_per_turn": 0.50,
        "parallel_tools": true,
        "early_exit_on": ["no_tools", "explicit_done", "budget_exceeded"],
        "mode": "internal | external_open | external_undercover"
      }
    },
    "events_emitted": [
      "TurnStarted",
      "ModelOutput", 
      "ToolCall",
      "ToolResult",
      "TurnCompleted",
      "BudgetExceeded",
      "ConstitutionalViolation",
      "LoopCompleted"
    ]
  },

  "tool_registry_schema": {
    "fields": {
      "name": "string — unique identifier",
      "description": "human-readable purpose",
      "schema": "JSON Schema for arguments",
      "risk_tier": "safe | guarded | high_risk | critical",
      "permission_tier": "Tier1 | Tier2 | Tier3 (see ToolPolicyEngine)",
      "mcp_server": "string — which MCP server exposes this",
      "requires_audit": "boolean — log to VAULT999",
      "concurrent_limit": "number — max parallel calls",
      "modes_allowed": ["internal", "external_open", "external_undercover"],
      "example_chain": "string — which standard chain this belongs to"
    }
  },

  "standard_chains": {
    "description": "Reusable FSM macros — tools advertise membership, LLM uses chain identifiers not tool lists",
    "fix_bug": {
      "steps": ["grep", "view", "edit", "bash", "test"],
      "audit_required": true,
      "risk_tier": "guarded"
    },
    "deploy": {
      "steps": ["build", "verify_signature", "push", "health_check"],
      "audit_required": true,
      "risk_tier": "high_risk"
    },
    "research": {
      "steps": ["web_search", "web_fetch", "summarize", "store_memory"],
      "audit_required": false,
      "risk_tier": "safe"
    },
    "context_discovery": {
      "steps": ["grep", "view", "view", "view"],
      "audit_required": false,
      "risk_tier": "safe"
    }
  },

  "tool_policy_engine": {
    "permission_matrix": {
      "Tier1_safe": {
        "requires_audit": false,
        "max_per_minute": 120,
        "concurrent_limit": 10,
        "modes": ["internal", "external_open", "external_undercover"]
      },
      "Tier2_guarded": {
        "requires_audit": true,
        "max_per_minute": 20,
        "concurrent_limit": 3,
        "modes": ["internal", "external_open"]
      },
      "Tier3_high_risk": {
        "requires_audit": true,
        "max_per_minute": 5,
        "concurrent_limit": 1,
        "modes": ["internal"]
      },
      "Tier4_critical": {
        "requires_audit": true,
        "max_per_minute": 1,
        "concurrent_limit": 1,
        "modes": ["internal"],
        "require_explicit_confirmation": true
      }
    },
    "pre_tool_check": "risk_tier → permission check → concurrent limit check → mode validation",
    "post_tool_audit": "log inputs/outputs/cost to VAULT999 if requires_audit=true"
  },

  "mode_system": {
    "internal": {
      "description": "Arif's private workspace — full tool access, all features enabled",
      "tool_allowlist": "all",
      "audit_level": "full_trace",
      "undercover_injection": false,
      "anti_distillation": false
    },
    "external_open": {
      "description": "Open source repos, public projects — discloses AI involvement, strips codenames",
      "tool_allowlist": "Tier1_safe + Tier2_guarded",
      "audit_level": "full_trace",
      "undercover_injection": "disclose_ai — don't hide, just don't leak internals",
      "anti_distillation": true
    },
    "external_undercover": {
      "description": "External repos where AI authorship should be hidden — BUDDY mode",
      "tool_allowlist": "Tier1_safe only",
      "audit_level": "full_trace",
      "undercover_injection": "full — rewrite git metadata, no AI co-author tags",
      "anti_distillation": true,
      "no_force_off": true
    }
  },

  "coordinator_pattern": {
    "description": "Coordinator agent — spawns child agents with constrained tool scopes, aggregates reports",
    "role": "never_shell_filesystem_directly",
    "tools": [
      "spawn_agent(agent_profile, task, tool_allowlist)",
      "list_active_agents()",
      "aggregate_reports(agent_ids[])",
      "kill_agent(agent_id)"
    ],
    "child_agent_constraints": {
      "max_turns_per_child": 20,
      "budget_per_child": 0.25,
      "timeout_per_task": "5 minutes",
      "inherit_mode_from": "coordinator"
    }
  },

  "background_scheduler": {
    "description": "Same agents invoked by scheduler — feeds kernel loop new tasks",
    "triggers": [
      {"type": "cron", "spec": "*/5 * * * *", "agent": "KAIROS", "task": "repo_health_check"},
      {"type": "webhook", "path": "/webhook/github", "agent": "KAIROS", "task": "pr_review"},
      {"type": "event", "event": "deploy_success", "agent": "BUDDY", "task": "notify_team"}
    ],
    "kairos": {
      "role": "always_on_background_agent",
      "memory": "persistent_session_memory",
      "cron_interval_minutes": 5,
      "github_webhooks": ["push", "pull_request", "issue_comment"]
    },
    "buddy": {
      "role": "companion_agent",
      "personality": "helpful_dev_assistant_continuous",
      "memory": "append_only_daily_log"
    }
  },

  "constitutional_pre_loop": {
    "system_prompt_injection": [
      "F1: Delta (Clarity) — reduce entropy, dS <= 0",
      "F4: Psi (Vitality) — every action witnessed and auditable", 
      "F7: Omega (Humility) — stay within uncertainty band",
      "truth_power_coupling: authority_budget <= evidence_score"
    ],
    "pre_filters": [
      "regex: strip internal_codename_patterns (Capybara|Tengu|Fennec)",
      "regex: strip slack_urls_and_shortlinks",
      "regex: strip unreleased_version_numbers"
    ]
  },

  "constitutional_post_loop": {
    "pre_action_checks": [
      "git: verify no internal names in commit message",
      "shell: run 23-point bashSecurity validation",
      "api: verify no secrets in request body",
      "cost: confirm within budget before LLM call"
    ],
    "post_action_audit": {
      "log_to_vault999": "always",
      "constitutional_compliance_check": "888_JUDGE reviews if risk_tier >= Tier2"
    }
  }
}
