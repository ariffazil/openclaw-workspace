{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.ariffazil/arifos-mcp",
  "version": "2026.2.27",
  "protocolVersion": "2025-11-25",
  "supportedProtocolVersions": [
    "2025-11-25",
    "2025-03-26"
  ],
  "title": "arifOS Sovereign Governance MCP",
  "description": "Constitutional AI governance server exposing governed AAA MCP 13-tool pipeline.",
  "websiteUrl": "https://arifos.arif-fazil.com/",
  "vendor": {
    "name": "arifOS",
    "url": "https://arifos.arif-fazil.com"
  },
  "license": "AGPL-3.0-only",
  "repository": {
    "url": "https://github.com/ariffazil/arifOS",
    "source": "github"
  },
  "packages": [
    {
      "registryType": "pypi",
      "identifier": "arifos",
      "version": "2026.2.27",
      "transport": {
        "type": "stdio"
      }
    },
    {
      "registryType": "oci",
      "identifier": "ghcr.io/ariffazil/arifos:latest",
      "transport": {
        "type": "streamable-http",
        "url": "https://arifosmcp.arif-fazil.com/mcp"
      }
    }
  ],
  "remotes": [
    {
      "type": "streamable-http",
      "url": "https://arifosmcp.arif-fazil.com/mcp"
    },
    {
      "type": "sse",
      "url": "https://arifosmcp.arif-fazil.com/sse"
    }
  ],
  "resources": [
    {
      "uri": "arifos://aaa/schemas",
      "description": "Canonical AAA MCP schema and tool metadata"
    },
    {
      "uri": "arifos://aaa/full-context-pack",
      "description": "Canonical full-context pack for governed orchestration"
    }
  ],
  "prompts": [
    "arifos.prompt.aaa_chain"
  ]
}
