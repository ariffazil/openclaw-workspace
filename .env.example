# Grafana admin password — REQUIRED for production
# Run: cp .env.example .env && edit GRAFANA_ADMIN_PASSWORD
GRAFANA_ADMIN_PASSWORD=changeme

# Supabase L4 connection (for Federation Memory Cockpit — Phase 3A)
# Get these from: https://supabase.com/dashboard/project/utbmmjmbolmuahwixjqc/settings/api
VITE_SUPABASE_URL=https://utbmmjmbolmuahwixjqc.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

