# =============================================================================
# arifOS MCP Server - Environment Configuration Template
# =============================================================================
# Version: 1.0.0
# Constitutional Compliance: F11 (Authority) - Requires explicit configuration
#
# ⚠️⚠️⚠️ 888_HOLD SECURITY WARNING ⚠️⚠️⚠️
# This file contains SENSITIVE configuration templates. 
# DO NOT commit .env files with real values to version control!
#
# F11 COMPLIANCE CHECKLIST:
# [ ] All secrets are generated with cryptographically secure randomness
# [ ] Production passwords are 32+ characters
# [ ] API keys are rotated every 90 days
# [ ] .env is in .gitignore
# [ ] Access to production .env requires multi-factor authentication
#
# MOTTO: Ditempa Bukan Diberi — Forged, Not Given
# =============================================================================

# =============================================================================
# 1. CORE SERVER CONFIGURATION
# =============================================================================

# Environment mode: development | staging | production
NODE_ENV=production

# Server binding
ARIFOS_HOST=0.0.0.0
ARIFOS_PORT=8888
ARIFOS_PUBLIC_BASE_URL=https://arifosmcp.arif-fazil.com
ARIFOS_WIDGET_DOMAIN=https://arifosmcp.arif-fazil.com

# =============================================================================
# 2. DATABASE CONFIGURATION (Vault-999 + Relational State)
# =============================================================================

# PostgreSQL - Vault-999 Core
# ⚠️ 888_HOLD: Generate strong password for production (min 32 chars)
POSTGRES_DB=arifos_vault
POSTGRES_USER=arifos_admin
POSTGRES_PASSWORD=CHANGE_ME_IN_PRODUCTION_MIN_32_CHARS
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432

# Full connection URL (auto-generated from above)
# DATABASE_URL=postgresql://arifos_admin:PASSWORD@postgres:5432/arifos_vault

# =============================================================================
# 3. CACHE & SESSION CONFIGURATION
# =============================================================================

# Redis - Session & Cache Layer
# ⚠️ 888_HOLD: Change default password in production
REDIS_PASSWORD=CHANGE_ME_REDIS_STRONG_PASSWORD
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_SESSION_TTL=3600

# =============================================================================
# 4. VECTOR DATABASE CONFIGURATION (Qdrant)
# =============================================================================

# Qdrant - Vector Memory / Embeddings
# ⚠️ 888_HOLD: Set strong API key for production
QDRANT_API_KEY=CHANGE_ME_QDRANT_API_KEY_MIN_32_CHARS
QDRANT_HOST=127.0.0.1
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_LOG_LEVEL=INFO
QDRANT_COLLECTION=arifos_memory

# =============================================================================
# 5. AGENTZERO CONFIGURATION (Reasoning Brain / RAG)
# =============================================================================

# AgentZero Service
AGENTZERO_HOST=127.0.0.1
AGENTZERO_PORT=8080
AGENTZERO_URL=http://agentzero:8080
AGENTZERO_API_KEY=CHANGE_ME_AGENTZERO_KEY

# Constitutional Settings
AGENTZERO_CONSTITUTIONAL_MODE=strict
AGENTZERO_FLOOR_F2_MIN=0.99
AGENTZERO_888_HOLD_ENABLED=true
AGENTZERO_LOG_LEVEL=INFO

# RAG Configuration
RAG_TOP_K=5
RAG_SIMILARITY_THRESHOLD=0.85
EMBEDDING_MODEL=text-embedding-3-large

# =============================================================================
# 6. OPENCLAW CONFIGURATION (Multi-Channel IO)
# =============================================================================

# OpenClaw Service
OPENCLAW_HOST=127.0.0.1
OPENCLAW_PORT=3000
OPENCLAW_URL=http://openclaw:3000
OPENCLAW_API_KEY=CHANGE_ME_OPENCLAW_KEY

# OpenClaw Mode: judgment | relay | hybrid
OPENCLAW_MODE=judgment

# ⚠️ 888_HOLD: Generate cryptographically secure webhook secret
OPENCLAW_WEBHOOK_SECRET=CHANGE_ME_WEBHOOK_SECRET_MIN_64_CHARS

# Channel Configuration
DEFAULT_CHANNEL_PRIORITY=telegram,whatsapp
CHANNEL_FALLBACK_ENABLED=true
OPENCLAW_POLICY_ENFORCEMENT=strict
MESSAGE_RATE_LIMIT_PER_MIN=60
MAX_MESSAGE_LENGTH=4096

# WhatsApp Business API
# ⚠️ 888_HOLD: These are production credentials from Meta Business
WHATSAPP_API_TOKEN=YOUR_WHATSAPP_API_TOKEN
WHATSAPP_PHONE_NUMBER_ID=YOUR_PHONE_NUMBER_ID
WHATSAPP_BUSINESS_ACCOUNT_ID=YOUR_BUSINESS_ACCOUNT_ID
WHATSAPP_WEBHOOK_VERIFY_TOKEN=YOUR_VERIFY_TOKEN

# Telegram Bot API
# ⚠️ 888_HOLD: Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
TELEGRAM_WEBHOOK_URL=https://api.yourdomain.com/webhook/telegram

OPENCLAW_LOG_LEVEL=INFO

# =============================================================================
# 7. CONSTITUTIONAL GOVERNANCE CONFIGURATION (F1-F13)
# =============================================================================

# F1: Amanah (Reversibility)
ARIFOS_F1_AMANAH_ENABLED=true
ARIFOS_BACKUP_REQUIRED=true

# F2: Truth (τ ≥ 0.99)
ARIFOS_F2_TRUTH_THRESHOLD=0.99
ARIFOS_FACT_VERIFICATION=strict

# F4: Clarity (ΔS ≤ 0)
ARIFOS_F4_ENTROPY_CHECK=true
ARIFOS_MAX_QUERY_COMPLEXITY=100

# F5: Peace² (Non-destructive)
ARIFOS_F5_PEACE_ENABLED=true
ARIFOS_SAFE_MODE=true

# F6: Empathy (κᵣ ≥ 0.70)
ARIFOS_F6_EMPATHY_THRESHOLD=0.70
ARIFOS_WEAKEST_STAKEHOLDER_BIAS=true

# F7: Humility (Ω₀ ∈ [0.03, 0.05])
ARIFOS_F7_HUMILITY_TARGET=0.04
ARIFOS_UNCERTAINTY_ACKNOWLEDGMENT=required

# F8: Genius (G ≥ 0.80)
ARIFOS_F8_GENIUS_THRESHOLD=0.80
ARIFOS_COHERENCE_CHECK=true

# F9: Anti-Hantu (No consciousness claims)
ARIFOS_F9_ANTIHANTU_ENABLED=true
ARIFOS_SYMBOLIC_MODE=strict

# F11: Command Authority
ARIFOS_F11_AUTH_REQUIRED=true
ARIFOS_NONCE_VERIFICATION=true

# F12: Injection Defense
ARIFOS_F12_INJECTION_DEFENSE=true
ARIFOS_INPUT_SANITIZATION=strict

# 888_HOLD Configuration
ARIFOS_888_HOLD_ENABLED=true
ARIFOS_888_HOLD_MUTATIONS=true
ARIFOS_888_HOLD_SECRETS=true
ARIFOS_888_HOLD_DESTRUCTIVE=true

# =============================================================================
# 8. API KEYS - LLM PROVIDERS
# =============================================================================

# ⚠️⚠️⚠️ 888_HOLD: Production API Keys ⚠️⚠️⚠️
# These keys provide access to external AI services.
# Rotate every 90 days. Monitor usage for anomalies.

# OpenAI
OPENAI_API_KEY=sk-CHANGE_ME_OPENAI_KEY

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-CHANGE_ME_ANTHROPIC_KEY

# Google (Gemini)
GEMINI_API_KEY=CHANGE_ME_GEMINI_KEY

# Default model for reasoning
DEFAULT_MODEL=claude-sonnet-4-20250514

# =============================================================================
# 9. SECURITY & ENCRYPTION
# =============================================================================

# ⚠️ 888_HOLD: Generate these with: openssl rand -hex 64
# NEVER use the same keys across environments
#
# FOR PRODUCTION: Use file-based secrets (see DEPLOY_SECRETS.md)
#   1. Run: .\scripts\init-secrets.ps1 (Windows) or scripts/init-secrets.sh (Linux)
#   2. Reference the generated files below instead of inline secrets

# =============================================================================
# 9a. FILE-BASED SECRETS (Production Recommended)
# =============================================================================
# These variables point to secret files (outside version control)
# The actual secrets are read from these files on startup
# This ensures F11 session continuity across restarts

# Path to governance secret file (64+ chars, persistent across restarts)
# ARIFOS_GOVERNANCE_SECRET_FILE=/etc/arifos/secrets/governance.secret
# ARIFOS_GOVERNANCE_SECRET_FILE=C:\arifos\secrets\governance.secret

# Path to session secret file
# ARIFOS_SESSION_SECRET_FILE=/etc/arifos/secrets/session.secret
# ARIFOS_SESSION_SECRET_FILE=C:\arifos\secrets\session.secret

# PostgreSQL password file (Docker secrets compatible)
# POSTGRES_PASSWORD_FILE=/run/secrets/postgres_password

# Redis password file
# REDIS_PASSWORD_FILE=/run/secrets/redis_password

# Qdrant API key file
# QDRANT_API_KEY_FILE=/run/secrets/qdrant_api_key

# =============================================================================
# 9b. INLINE SECRETS (Development Only - Not for Production)
# =============================================================================
# ⚠️ WARNING: Inline secrets are ephemeral and break F11 continuity on restart.
# Use file-based secrets above for production deployments.

# Governance Secret (F11 Root of Trust)
# If ARIFOS_GOVERNANCE_SECRET_FILE is set, this is ignored
ARIFOS_GOVERNANCE_SECRET=CHANGE_ME_GOVERNANCE_SECRET_MIN_64_CHARS

# JWT Signing Secret (legacy, will be replaced by GOVERNANCE_SECRET)
JWT_SECRET=CHANGE_ME_JWT_SECRET_MIN_64_CHARS_HEX

# API Key Salt (for hashing)
API_KEY_SALT=CHANGE_ME_SALT_MIN_32_CHARS

# Session Encryption
# If ARIFOS_SESSION_SECRET_FILE is set, this is ignored
SESSION_SECRET=CHANGE_ME_SESSION_SECRET_MIN_64_CHARS

# Field-level Encryption Key
ENCRYPTION_KEY=CHANGE_ME_ENCRYPTION_KEY_32_CHARS

# Docker Secrets Strict Mode (disables fallback to env vars)
# ARIFOS_SECRET_STRICT_MODE=true

# =============================================================================
# 10. LOGGING & OBSERVABILITY
# =============================================================================

ARIFOS_LOG_LEVEL=INFO
AUDIT_LOG_ENABLED=true

# =============================================================================
# 11. NGINX / SSL CONFIGURATION
# =============================================================================

NGINX_ARIFOS_HOST=arifos
DOMAIN=localhost
SSL_ENABLED=false

# For Let's Encrypt / Certbot
# CERTBOT_EMAIL=admin@yourdomain.com
# CERTBOT_STAGING=false

# =============================================================================
# 12. INTEGRATION ENDPOINTS
# =============================================================================

# Internal service discovery
ARIFOS_MCP_URL=http://arifos:8888
ARIFOS_MCP_API_KEY=CHANGE_ME_MCP_API_KEY

# =============================================================================
# 13. MICROSOFT COPILOT STUDIO INTEGRATION
# =============================================================================
# Tool profile for the canonical public surface.
# Other profiles: internal | full | copilot | chatgpt | agnostic_public
ARIFOS_PUBLIC_TOOL_PROFILE=public

# Optional API key for Copilot Studio X-API-Key authentication.
# Set to a secure random string to enable auth guard.
# Leave empty (or unset) to run in open/development mode.
# Generate: openssl rand -hex 32
# In Copilot Studio wizard: Authentication -> API Key -> Header -> X-API-Key
COPILOT_API_KEY=

AGENTZERO_ENABLED=true
OPENCLAW_ENABLED=true

# =============================================================================
# END OF CONFIGURATION
# =============================================================================
# REMEMBER: 
# 1. Copy this file to .env and fill in real values
# 2. Run: chmod 600 .env (restrict permissions)
# 3. Add .env to .gitignore
# 4. Use a secrets manager in production (e.g., AWS Secrets Manager, Vault)
#
# FOR PRODUCTION SECRETS MANAGEMENT:
#   See DEPLOY_SECRETS.md for Docker Secrets, file-based secrets, and rotation
#   Run: .\scripts\init-secrets.ps1 to generate secure secrets (Windows)
#   Run: scripts/init-secrets.sh to generate secure secrets (Linux/macOS)
#
# F11 CONTINUITY REQUIREMENT:
#   ARIFOS_GOVERNANCE_SECRET must be PERSISTENT across restarts.
#   Ephemeral secrets invalidate all auth_context tokens on restart.
#   Use ARIFOS_GOVERNANCE_SECRET_FILE with a stable file path.
# =============================================================================
