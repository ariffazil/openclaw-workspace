{
  "profile": "prod",
  "strict_mode": true,
  "preflight": {
    "anti_hantu_enabled": true,
    "irreversible_keywords": ["delete", "drop", "truncate", "deploy", "publish", "overwrite", "migration", "rotate"],
    "omega0": {
      "elevated": 0.05,
      "critical": 0.08
    }
  },
  "pipeline": {
    "order": ["ARCHITECT", "AUDITOR", "ENGINEER", "VALIDATOR"],
    "halt_on_auditor_non_seal": true,
    "validator_requires_auditor_clear": true
  }
}
