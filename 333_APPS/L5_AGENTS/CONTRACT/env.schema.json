{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "L5 Runtime Env Contract",
  "type": "object",
  "required": ["profile", "strict_mode", "preflight", "pipeline"],
  "properties": {
    "profile": {"type": "string", "enum": ["dev", "prod"]},
    "strict_mode": {"type": "boolean"},
    "preflight": {
      "type": "object",
      "required": ["anti_hantu_enabled", "irreversible_keywords", "omega0"],
      "properties": {
        "anti_hantu_enabled": {"type": "boolean"},
        "irreversible_keywords": {"type": "array", "items": {"type": "string"}},
        "omega0": {
          "type": "object",
          "required": ["elevated", "critical"],
          "properties": {
            "elevated": {"type": "number"},
            "critical": {"type": "number"}
          }
        }
      }
    },
    "pipeline": {
      "type": "object",
      "required": ["order", "halt_on_auditor_non_seal", "validator_requires_auditor_clear"],
      "properties": {
        "order": {"type": "array", "items": {"type": "string"}},
        "halt_on_auditor_non_seal": {"type": "boolean"},
        "validator_requires_auditor_clear": {"type": "boolean"}
      }
    }
  }
}
