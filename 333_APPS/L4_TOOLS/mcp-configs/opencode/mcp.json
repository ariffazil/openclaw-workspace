{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$comment": "arifOS AAA MCP v64.1-GAGI — OpenCode Config (Cross‑Platform)",
  "mcpServers": {
    "aaa-mcp": {
      "command": "python3",
      "args": ["-m", "aaa_mcp", "stdio"],
      "cwd": "../../../../",
      "env": {
        "PYTHONPATH": ".",
        "ARIFOS_CONSTITUTIONAL_MODE": "AAA",
        "PYTHONIOENCODING": "utf-8",
        "PYTHONUNBUFFERED": "1"
      },
      "disabled": false,
      "alwaysAllow": [
        "anchor",
        "reason",
        "integrate",
        "respond",
        "validate",
        "align",
        "forge",
        "audit",
        "seal"
      ]
    }
  }
}
